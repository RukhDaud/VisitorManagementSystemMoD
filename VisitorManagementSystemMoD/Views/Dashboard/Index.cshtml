        // --- Export functions for Report Modal ---
        function exportReportExcel() {
            if (!lastReportData || !lastReportData.data || !lastReportData.data.length) { alert('No report data to export.'); return; }
            var headers = ['Name', 'CNIC', 'Purpose', 'Host', 'Department', 'Check-In', 'Check-Out', 'Status'];
            var rows = lastReportData.data.map(function(v) {
                return [v.name, v.cnic, v.purpose, v.employeeName, v.departmentName, v.checkInTime, v.checkOutTime, v.isLateCheckout ? 'Late Checkout' : 'Normal'];
            });
            rows.unshift(headers);
            var ws = XLSX.utils.aoa_to_sheet(rows);
            var wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Report');
            ws['!cols'] = headers.map(function() { return { wch: 20 }; });
            XLSX.writeFile(wb, 'Visitor_Report_' + new Date().toISOString().slice(0,10) + '.xlsx');
        }

        function exportReportPdf() {
            if (!lastReportData || !lastReportData.data || !lastReportData.data.length) { alert('No report data to export.'); return; }
            var { jsPDF } = window.jspdf;
            var doc = new jsPDF('landscape', 'mm', 'a4');
            var typeLabel = lastReportData.type === 'checkedin' ? 'Check-In' : 'Check-Out';
            doc.setFontSize(16);
            doc.text(typeLabel + ' Report - ' + lastReportData.period, 14, 15);
            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text('Period: ' + lastReportData.startDate + ' - ' + lastReportData.endDate, 14, 22);
            var headers = ['Name', 'CNIC', 'Purpose', 'Host', 'Department', 'Check-In', 'Check-Out', 'Status'];
            var rows = lastReportData.data.map(function(v) {
                return [v.name, v.cnic, v.purpose, v.employeeName, v.departmentName, v.checkInTime, v.checkOutTime, v.isLateCheckout ? 'Late Checkout' : 'Normal'];
            });
            doc.autoTable({ head: [headers], body: rows, startY: 27, styles: { fontSize: 7, cellPadding: 2 }, headStyles: { fillColor: [59, 130, 246], textColor: 255 }, alternateRowStyles: { fillColor: [248, 249, 250] }, margin: { left: 14, right: 14 } });
            doc.save('Visitor_Report_' + new Date().toISOString().slice(0,10) + '.pdf');
        }

        function printReport() {
            if (!lastReportData || !lastReportData.data || !lastReportData.data.length) { alert('No report data to print.'); return; }
            var content = document.getElementById('reportContent').innerHTML;
            var printWin = window.open('', '_blank');
            printWin.document.write('<!DOCTYPE html><html><head><title>Visitor Report<' + '/title>');
            printWin.document.write('<style>body{font-family:Arial,sans-serif;margin:20px;}table{width:100%;border-collapse:collapse;font-size:11px;}th,td{border:1px solid #ddd;padding:6px 8px;text-align:left;}th{background:#3b82f6;color:#fff;}.badge{padding:2px 6px;border-radius:4px;font-size:9px;}.bg-warning{background:#f59e0b;}.bg-success{background:#10b981;color:#fff;}<' + '/style>');
            printWin.document.write('<' + '/head><body>');
            printWin.document.write(content);
            printWin.document.write('<' + '/body><' + '/html>');
            printWin.document.close();
            printWin.onload = function() { printWin.print(); };
        }

        // --- Export functions for Modal tables (CheckedIn/CheckedOut) ---
        function exportModalExcel(modalId, filename) {
            var table = document.querySelector('#' + modalId + ' table');
            if (!table) { alert('No data to export.'); return; }
            var wb = XLSX.utils.table_to_book(table, { sheet: 'Data' });
            XLSX.writeFile(wb, filename + '_' + new Date().toISOString().slice(0,10) + '.xlsx');
        }

        function exportModalPdf(modalId, title) {
            var table = document.querySelector('#' + modalId + ' table');
            if (!table) { alert('No data to export.'); return; }
            var { jsPDF } = window.jspdf;
            var doc = new jsPDF('landscape', 'mm', 'a4');
            doc.setFontSize(16);
            doc.text(title, 14, 15);
            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);
            var headers = [];
            var rows = [];
            table.querySelectorAll('thead th').forEach(function(th) { headers.push(th.textContent.trim()); });
            table.querySelectorAll('tbody tr').forEach(function(tr) {
                var row = [];
                tr.querySelectorAll('td').forEach(function(td) { row.push(td.textContent.trim()); });
                if (row.length) rows.push(row);
            });
            doc.autoTable({ head: [headers], body: rows, startY: 27, styles: { fontSize: 7, cellPadding: 2 }, headStyles: { fillColor: [59, 130, 246], textColor: 255 }, alternateRowStyles: { fillColor: [248, 249, 250] }, margin: { left: 14, right: 14 } });
            doc.save(title.replace(/\s+/g, '_') + '_' + new Date().toISOString().slice(0,10) + '.pdf');
        }

        function printModal(modalId, title) {
            var table = document.querySelector('#' + modalId + ' table');
            if (!table) { alert('No data to print.'); return; }
            var printWin = window.open('', '_blank');
            printWin.document.write('<!DOCTYPE html><html><head><title>' + title + '<' + '/title>');
            printWin.document.write('<style>body{font-family:Arial,sans-serif;margin:20px;}table{width:100%;border-collapse:collapse;font-size:11px;}th,td{border:1px solid #ddd;padding:6px 8px;text-align:left;}th{background:#3b82f6;color:#fff;}h2{margin-bottom:4px;}p{color:#666;margin-top:0;}<' + '/style>');
            printWin.document.write('<' + '/head><body>');
            printWin.document.write('<h2>' + title + '<' + '/h2>');
            printWin.document.write('<p>Generated: ' + new Date().toLocaleString() + '<' + '/p>');
            printWin.document.write(table.outerHTML);
            printWin.document.write('<' + '/body><' + '/html>');
            printWin.document.close();
            printWin.onload = function() { printWin.print(); };
        }

        // Filter inline list tables by search text
        function filterInlineList(input, tbodyId) {
            var searchText = input.value.toLowerCase();
            var rows = document.querySelectorAll('#' + tbodyId + ' tr');
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchText) ? '' : 'none';
            });
        }
        </script>

