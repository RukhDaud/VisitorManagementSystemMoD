                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.CheckedOutVisitorsList)
                                    {
                                        <tr>
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@(visitor.CheckInTime?.ToString("MMM dd, h:mm tt") ?? "-")</td>
                                            <td>@(visitor.CheckOutTime?.ToString("MMM dd, h:mm tt") ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No checked out visitors</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: @Model.CheckedOutVisitorsList.Count visitor(s)</span>
                    <button type="button" class="btn btn-sm btn-success" onclick="exportModalExcel('CheckedOutModal', 'CheckedOut_Visitors')"><i class="fas fa-file-excel me-1"></i>Excel</button>
