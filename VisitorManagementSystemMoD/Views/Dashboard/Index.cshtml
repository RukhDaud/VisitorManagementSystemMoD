                </div>
                <div class="modal-body">
                    @if (Model.RecentVisitors.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Check-In</th>
                                        <th>Check-Out</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.RecentVisitors)
                                    {
                                        <tr>
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@(visitor.CheckInTime?.ToString("h:mm tt") ?? "-")</td>
                                            <td>@(visitor.CheckOutTime?.ToString("h:mm tt") ?? "-")</td>
                                            <td>
                                                @if (visitor.CheckOutTime.HasValue)
                                                {
                                                    <span class="badge bg-secondary">Checked Out</span>
                                                }
                                                else if (visitor.CheckInTime.HasValue)
                                                {
                                                    <span class="badge bg-success">Inside</span>
                                                }
