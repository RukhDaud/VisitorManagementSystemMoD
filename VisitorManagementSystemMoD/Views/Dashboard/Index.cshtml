@model VisitorManagementSystemMoD.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var userRole = ViewBag.UserRole as string;
    var userName = Context.Session.GetString("UserName");
    var isEmployeeDashboard = userRole == "Employee" || userRole == "Section Officer"
        || (userRole != "Security Officer" && userRole != "Reception" && userRole != "Admin" && userRole != "SuperAdmin" && userRole != "Barrier Gate");
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page"><i class="fas fa-home"></i> Dashboard</li>
        </ol>
    </nav>
}

<div class="mb-4">
    <h1 class="display-6 fw-bold">
        Welcome, @userName
    </h1>
    <p class="text-muted">
        @if (isEmployeeDashboard)
        {
            <text>Manage your visitor requests</text>
        }
        else if (userRole == "Security Officer")
        {
            <text>Chief Security Officer - Approval Management</text>
        }
        else if (userRole == "Reception")
        {
            <text>Reception - Visitor Check-In/Check-Out</text>
        }
        else if (userRole == "Admin" || userRole == "SuperAdmin")
        {
            <text>System Overview & Analytics</text>
        }
    </p>
</div>

<!-- KPI Cards - Redesigned with 6 Cards -->
@if (userRole == "Admin" || userRole == "SuperAdmin" || userRole == "Security Officer")
{
    <div class="row g-3 mb-4">
        <!-- Row 1: Total, Pending, Approved, Rejected -->
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#TotalVisitorsModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-primary fw-semibold mb-1 small">Total Visitors</p>
                            <h4 class="fw-bold mb-0">@Model.TotalVisitors</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-users fa-lg text-primary"></i>
                        </div>
                    </div>
                    <small class="text-primary mt-1 d-block" style="font-size: 0.75rem;">View all →</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#PendingModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-warning fw-semibold mb-1 small">Pending</p>
                            <h4 class="fw-bold mb-0">@Model.PendingRequests</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-clock fa-lg text-warning"></i>
                        </div>
                    </div>
                    <small class="text-warning mt-1 d-block" style="font-size: 0.75rem;">Review →</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #d1fae5 0%, #6ee7b7 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#ApprovedModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-success fw-semibold mb-1 small">Approved</p>
                            <h4 class="fw-bold mb-0">@Model.ApprovedRequests</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-check-circle fa-lg text-success"></i>
                        </div>
                    </div>
                    <small class="text-success mt-1 d-block" style="font-size: 0.75rem;">View →</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #fee2e2 0%, #fca5a5 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#RejectedModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-danger fw-semibold mb-1 small">Rejected</p>
                            <h4 class="fw-bold mb-0">@Model.RejectedRequests</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-times-circle fa-lg text-danger"></i>
                        </div>
                    </div>
                    <small class="text-danger mt-1 d-block" style="font-size: 0.75rem;">View →</small>
                </div>
            </div>
        </div>
    </div>
    <!-- Second row: Checked In/Checked Out -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #d1fae5 0%, #6ee7b7 100%); cursor:pointer;" onclick="new bootstrap.Modal(document.getElementById('CheckedInModal')).show()">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-success fw-semibold mb-1 small">Checked In</p>
                            <h4 class="fw-bold mb-0" id="checkedInCount">@Model.CheckedInVisitors</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-user-check fa-lg text-success"></i>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <div class="d-flex gap-2">
                            <a href="javascript:void(0)" onclick="event.stopPropagation(); refreshCounts();" title="Refresh Counts" class="text-success">
                                <i class="fas fa-sync-alt"></i>
                            </a>
                            <div class="dropup" onclick="event.stopPropagation();">
                                <a href="javascript:void(0)" class="text-success" data-bs-toggle="dropdown" data-bs-auto-close="true" title="Generate Report">
                                    <i class="fas fa-file-alt"></i>
                                </a>
                                <ul class="dropdown-menu shadow" style="min-width: 160px;">
                                    <li><h6 class="dropdown-header">Check-In Report</h6></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','today')"><i class="fas fa-calendar-day me-2"></i>Today</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','weekly')"><i class="fas fa-calendar-week me-2"></i>Weekly</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','monthly')"><i class="fas fa-calendar-alt me-2"></i>Monthly</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','yearly')"><i class="fas fa-calendar me-2"></i>Yearly</a></li>
                                </ul>
                            </div>
                        </div>
                        <small class="text-success" style="font-size: 0.75rem;">View Details →</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #ddd6fe 0%, #a78bfa 100%); cursor:pointer;" onclick="new bootstrap.Modal(document.getElementById('CheckedOutModal')).show()">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="fw-semibold mb-1 small" style="color: #7c3aed;">Checked Out</p>
                            <h4 class="fw-bold mb-0" id="checkedOutCount">@Model.CheckedOutVisitors</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-sign-out-alt fa-lg" style="color: #7c3aed;"></i>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <div class="d-flex gap-2">
                            <a href="javascript:void(0)" onclick="event.stopPropagation(); refreshCounts();" title="Refresh Counts" style="color: #7c3aed;">
                                <i class="fas fa-sync-alt"></i>
                            </a>
                            <div class="dropup" onclick="event.stopPropagation();">
                                <a href="javascript:void(0)" style="color: #7c3aed;" data-bs-toggle="dropdown" data-bs-auto-close="true" title="Generate Report">
                                    <i class="fas fa-file-alt"></i>
                                </a>
                                <ul class="dropdown-menu shadow" style="min-width: 160px;">
                                    <li><h6 class="dropdown-header">Check-Out Report</h6></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','today')"><i class="fas fa-calendar-day me-2"></i>Today</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','weekly')"><i class="fas fa-calendar-week me-2"></i>Weekly</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','monthly')"><i class="fas fa-calendar-alt me-2"></i>Monthly</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','yearly')"><i class="fas fa-calendar me-2"></i>Yearly</a></li>
                                </ul>
                            </div>
                        </div>
                        <small style="color: #7c3aed; font-size: 0.75rem;">View Details →</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Today's Expected & Recent Activity - Inline Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100 inline-data-card" id="todayExpectedCard" style="border: none; border-left: 3px solid #3b82f6; border-radius: 0.5rem;">
                <div class="card-header d-flex justify-content-between align-items-center py-2" style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border-bottom: 1px solid #bfdbfe;">
                    <h6 class="mb-0 fw-semibold small"><i class="fas fa-calendar-day me-2 text-primary"></i>Today's Expected <span class="badge bg-primary rounded-pill ms-1" style="font-size: 0.65rem;">@Model.TodayVisitors.Count</span></h6>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-secondary py-0 px-1" onclick="location.reload()" title="Refresh"><i class="fas fa-sync-alt"></i></button>
                        <button class="btn btn-sm btn-outline-success py-0 px-1" onclick="exportModalExcel('todayExpectedCard','TodayExpected')" title="Excel"><i class="fas fa-file-excel"></i></button>
                        <button class="btn btn-sm btn-outline-danger py-0 px-1" onclick="exportModalPdf('todayExpectedCard','Today Expected Visitors')" title="PDF"><i class="fas fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-outline-primary py-0 px-1" onclick="printModal('todayExpectedCard','Today Expected Visitors')" title="Print"><i class="fas fa-print"></i></button>
                    </div>
                </div>
                <div class="card-body p-2">
                    <div class="input-group input-group-sm mb-2">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-search text-muted" style="font-size: 0.7rem;"></i></span>
                        <input type="text" class="form-control form-control-sm border-start-0" placeholder="Search visitors..." onkeyup="filterInlineList(this, 'todayExpectedBody')">
                    </div>
                    <div class="table-responsive inline-table-scroll" style="max-height: 280px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light" style="position: sticky; top: 0;">
                                <tr>
                                    <th>Name</th>
                                    <th>Host</th>
                                    <th>Expected</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="todayExpectedBody">
                                @if (Model.TodayVisitors.Any())
                                {
                                    @foreach (var visitor in Model.TodayVisitors)
                                    {
                                        <tr>
                                            <td class="small"><a class="visitor-link" href="javascript:void(0)" onclick="showVisitorDetail(@visitor.Id)"><strong>@visitor.Name</strong></a></td>
                                            <td class="small">@visitor.EmployeeName</td>
                                            <td class="small">@visitor.ExpectedTime.ToString("h:mm tt")</td>
                                            <td>
                                                @if (visitor.CheckOutTime.HasValue)
                                                {
                                                    <span class="badge bg-secondary" style="font-size:0.65rem;">Out</span>
                                                }
                                                else if (visitor.CheckInTime.HasValue)
                                                {
                                                    <span class="badge bg-success" style="font-size:0.65rem;">Inside</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark" style="font-size:0.65rem;">Pending</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-muted text-center py-4"><i class="fas fa-calendar-times me-2 opacity-50"></i><span class="small fst-italic">No visitors expected today</span></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100 inline-data-card" id="recentActivityCard" style="border: none; border-left: 3px solid #10b981; border-radius: 0.5rem;">
                <div class="card-header d-flex justify-content-between align-items-center py-2" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-bottom: 1px solid #a7f3d0;">
                    <h6 class="mb-0 fw-semibold small"><i class="fas fa-bolt me-2 text-success"></i>Recent Activity (Today) <span class="badge bg-success rounded-pill ms-1" style="font-size: 0.65rem;">@Model.RecentVisitors.Count</span></h6>
                    <button class="btn btn-sm btn-outline-secondary py-0 px-1" onclick="location.reload()" title="Refresh"><i class="fas fa-sync-alt"></i></button>
                </div>
                <div class="card-body p-2">
                    <div class="input-group input-group-sm mb-2">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-search text-muted" style="font-size: 0.7rem;"></i></span>
                        <input type="text" class="form-control form-control-sm border-start-0" placeholder="Search activity..." onkeyup="filterInlineList(this, 'recentActivityBody')">
                    </div>
                    <div class="table-responsive inline-table-scroll" style="max-height: 280px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light" style="position: sticky; top: 0;">
                                <tr>
                                    <th>Name</th>
                                    <th>Host</th>
                                    <th>Check-In</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="recentActivityBody">
                                @if (Model.RecentVisitors.Any())
                                {
                                    @foreach (var visitor in Model.RecentVisitors)
                                    {
                                        <tr>
                                            <td class="small"><a class="visitor-link" href="javascript:void(0)" onclick="showVisitorDetail(@visitor.Id)"><strong>@visitor.Name</strong></a></td>
                                            <td class="small">@visitor.EmployeeName</td>
                                            <td class="small">@(visitor.CheckInTime?.ToString("h:mm tt") ?? "-")</td>
                                            <td>
                                                @if (visitor.CheckOutTime.HasValue)
                                                {
                                                    <span class="badge bg-secondary" style="font-size:0.65rem;">Out</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success" style="font-size:0.65rem;">Inside</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-muted text-center py-4"><i class="fas fa-history me-2 opacity-50"></i><span class="small fst-italic">No recent activity today</span></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


    }
else if (isEmployeeDashboard)
{
    <!-- Employee KPI Cards - Row 1: Total, Pending, Approved, Rejected -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#EmpTotalModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-primary fw-semibold mb-1 small">Total Requests</p>
                            <h4 class="fw-bold mb-0">@Model.TotalVisitors</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-users fa-lg text-primary"></i>
                        </div>
                    </div>
                    <small class="text-primary mt-1 d-block" style="font-size: 0.75rem;">View all →</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#EmpPendingModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-warning fw-semibold mb-1 small">Pending</p>
                            <h4 class="fw-bold mb-0">@Model.PendingRequests</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-clock fa-lg text-warning"></i>
                        </div>
                    </div>
                    <small class="text-warning mt-1 d-block" style="font-size: 0.75rem;">Awaiting approval →</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #d1fae5 0%, #6ee7b7 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#EmpApprovedModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-success fw-semibold mb-1 small">Approved</p>
                            <h4 class="fw-bold mb-0">@Model.ApprovedRequests</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-check-circle fa-lg text-success"></i>
                        </div>
                    </div>
                    <small class="text-success mt-1 d-block" style="font-size: 0.75rem;">View →</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #fee2e2 0%, #fca5a5 100%); cursor:pointer;" data-bs-toggle="modal" data-bs-target="#EmpRejectedModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-danger fw-semibold mb-1 small">Rejected</p>
                            <h4 class="fw-bold mb-0">@Model.RejectedRequests</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-times-circle fa-lg text-danger"></i>
                        </div>
                    </div>
                    <small class="text-danger mt-1 d-block" style="font-size: 0.75rem;">View →</small>
                </div>
            </div>
        </div>
    </div>
    <!-- Employee Row 2: Checked In / Checked Out -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #d1fae5 0%, #6ee7b7 100%); cursor:pointer;" onclick="new bootstrap.Modal(document.getElementById('EmpCheckedInModal')).show()">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-success fw-semibold mb-1 small">Checked In</p>
                            <h4 class="fw-bold mb-0" id="empCheckedInCount">@Model.CheckedInVisitors</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-user-check fa-lg text-success"></i>
                        </div>
                    </div>
                    <small class="text-success mt-1 d-block" style="font-size: 0.75rem;">View Details →</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #ddd6fe 0%, #a78bfa 100%); cursor:pointer;" onclick="new bootstrap.Modal(document.getElementById('EmpCheckedOutModal')).show()">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="fw-semibold mb-1 small" style="color: #7c3aed;">Checked Out</p>
                            <h4 class="fw-bold mb-0" id="empCheckedOutCount">@Model.CheckedOutVisitors</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-sign-out-alt fa-lg" style="color: #7c3aed;"></i>
                        </div>
                    </div>
                    <small style="color: #7c3aed; font-size: 0.75rem;" class="mt-1 d-block">View Details →</small>
                </div>
            </div>
        </div>
    </div>
    <!-- Employee Row 3: Upcoming Visits / Recent Activity - Inline Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100 inline-data-card" id="empUpcomingCard" style="border: none; border-left: 3px solid #3b82f6; border-radius: 0.5rem;">
                <div class="card-header d-flex justify-content-between align-items-center py-2" style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border-bottom: 1px solid #bfdbfe;">
                    <h6 class="mb-0 fw-semibold small"><i class="fas fa-calendar me-2 text-primary"></i>Upcoming Visits <span class="badge bg-primary rounded-pill ms-1" style="font-size: 0.65rem;">@Model.UpcomingVisitors.Count</span></h6>
                </div>
                <div class="card-body p-2">
                    <div class="input-group input-group-sm mb-2">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-search text-muted" style="font-size: 0.7rem;"></i></span>
                        <input type="text" class="form-control form-control-sm border-start-0" placeholder="Search..." onkeyup="filterInlineList(this, 'empUpcomingBody')">
                    </div>
                    <div class="table-responsive inline-table-scroll" style="max-height: 280px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light" style="position: sticky; top: 0;">
                                <tr>
                                    <th>Name</th>
                                    <th>Purpose</th>
                                    <th>Expected</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="empUpcomingBody">
                                @if (Model.UpcomingVisitors.Any())
                                {
                                    @foreach (var visitor in Model.UpcomingVisitors)
                                    {
                                        <tr>
                                            <td class="small"><a class="visitor-link" href="javascript:void(0)" onclick="showVisitorDetail(@visitor.Id)"><strong>@visitor.Name</strong></a></td>
                                            <td class="small">@visitor.Purpose</td>
                                            <td class="small">@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>
                                                @if (visitor.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark" style="font-size:0.65rem;">Pending</span>
                                                }
                                                else if (visitor.Status == "Approved")
                                                {
