<!-- Additional Sections -->
<div class="row g-4">
    @if (isEmployeeDashboard)
    {
        <!-- Create New Request Card -->
        <div class="col-12">
            <div class="card shadow-sm" style="background: white; border: 1px solid #e5e7eb;">
                <div class="card-body text-center py-5">
                    <h3 class="mb-2">Create New Visitor Request</h3>
                    <p class="text-muted mb-4">Submit a new visitor for SCO approval</p>
                    <a asp-controller="Visitor" asp-action="Create" class="btn btn-primary btn-lg" style="background: #3b82f6; border: none; box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);">
                        <i class="fas fa-user-plus me-2"></i>Create Visitor Request
                    </a>
                </div>
            </div>
        </div>
    }
    else if (userRole == "Security Officer" || userRole == "Admin" || userRole == "SuperAdmin")
    {
        @if (Model.PendingRequests > 0 && userRole == "Security Officer")
        {
            <!-- Action Required Card -->
            <div class="col-12">
                <div class="card border-warning shadow-sm" style="background: white;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h4 class="mb-2"><i class="fas fa-exclamation-triangle text-warning me-2"></i>Action Required</h4>
                                <p class="mb-0">You have @Model.PendingRequests pending visitor request(s) awaiting approval</p>
                            </div>
                            <a asp-controller="Visitor" asp-action="PendingApprovals" class="btn btn-warning">
                                Review Now <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else if (userRole == "Reception")
    {
        <!-- Reception: no inline sections, all data in modals -->
    }
</div>

<!-- KPI Modals for Admin/Security Officer -->
@if (userRole == "Admin" || userRole == "SuperAdmin" || userRole == "Security Officer")
{
    <!-- Total Visitors Modal -->
    <div class="modal fade" id="TotalVisitorsModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-users me-2 text-primary"></i>Total Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.AllVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>CNIC</th>
                                        <th>Host</th>
                                        <th>Destination</th>
                                        <th>Purpose</th>
                                        <th>Expected Time</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.AllVisitorsList)
                                    {
                                        <tr>
                                            <td><a class="visitor-link" href="javascript:void(0)" onclick="showVisitorDetail(@visitor.Id)"><strong>@visitor.Name</strong></a></td>
                                            <td>@(visitor.CNIC ?? "-")</td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@(visitor.Department?.Name ?? "-")</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>
                                                @if (visitor.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                }
                                                else if (visitor.Status == "Approved")
                                                {
                                                    <span class="badge bg-success">Approved</span>
                                                }
                                                else if (visitor.Status == "Rejected")
                                                {
                                                    <span class="badge bg-danger">Rejected</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No visitors found</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: @Model.AllVisitorsList.Count visitor(s)</span>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Visitors Modal -->
    <div class="modal fade" id="PendingModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-clock me-2 text-warning"></i>Pending Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.PendingVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>CNIC</th>
                                        <th>Host</th>
                                        <th>Destination</th>
                                        <th>Purpose</th>
                                        <th>Expected Time</th>
                                        <th>Requested On</th>
                                        @if (userRole == "Security Officer")
                                        {
                                            <th class="text-center">Actions</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.PendingVisitorsList)
                                    {
                                        <tr id="pendingRow-@visitor.Id">
                                            <td>
                                                <a class="visitor-link" href="javascript:void(0)" onclick="showVisitorDetail(@visitor.Id)"><strong>@visitor.Name</strong></a>
                                            </td>
                                            <td>@(visitor.CNIC ?? "-")</td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@(visitor.Department?.Name ?? "-")</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>@visitor.RequestCreatedAt.ToString("MMM dd, h:mm tt")</td>
                                            @if (userRole == "Security Officer")
                                            {
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm">
                                                        <button type="button" class="btn btn-success btn-sm" onclick="approveVisitor(@visitor.Id, '@visitor.Name')" title="Approve">
                                                            <i class="fas fa-check me-1"></i>Approve
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" onclick="showRejectModal(@visitor.Id, '@visitor.Name')" title="Reject">
                                                            <i class="fas fa-times me-1"></i>Reject
                                                        </button>
                                                    </div>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No pending visitors</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: <span id="pendingTotalCount">@Model.PendingVisitorsList.Count</span> visitor(s)</span>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Rejection Reason Modal -->
    @if (userRole == "Security Officer")
    {
        <div class="modal fade" id="RejectReasonModal" tabindex="-1" style="z-index: 1060;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">
                            <i class="fas fa-times-circle me-2"></i>Reject Visitor
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="rejectVisitorId" />
                        <p class="mb-2">Rejecting visitor: <strong id="rejectVisitorName"></strong></p>
                        <div class="mb-2">
                            <label class="form-label fw-semibold small text-muted">Quick Responses</label>
                            <div class="d-flex flex-wrap gap-1">
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="$('#rejectionReason').val('Incomplete or missing documents').removeClass('is-invalid')">Incomplete documents</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="$('#rejectionReason').val('Security concern identified').removeClass('is-invalid')">Security concern</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="$('#rejectionReason').val('Unauthorized visit - not pre-approved').removeClass('is-invalid')">Unauthorized visit</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="$('#rejectionReason').val('Host not available at the requested time').removeClass('is-invalid')">Host unavailable</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="$('#rejectionReason').val('Visit purpose not valid or insufficient').removeClass('is-invalid')">Invalid purpose</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="$('#rejectionReason').val('Visitor is on the blocked list').removeClass('is-invalid')">Blocked visitor</button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="rejectionReason" class="form-label fw-semibold">Rejection Reason <span class="text-danger">*</span></label>
                            <textarea id="rejectionReason" class="form-control" rows="3" placeholder="Enter reason for rejection..." required></textarea>
                            <div class="invalid-feedback" id="rejectionReasonError">Rejection reason is required.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" onclick="confirmReject()">
                            <i class="fas fa-times me-1"></i>Confirm Rejection
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Approved Visitors Modal -->
    <div class="modal fade" id="ApprovedModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-check-circle me-2 text-success"></i>Approved Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.ApprovedVisitorsList.Any())
