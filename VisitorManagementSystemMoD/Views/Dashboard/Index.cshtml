                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.ExpectedTime.ToString("h:mm tt")</td>
                                            <td>
                                                @if (visitor.HasVehicle)
                                                {
                                                    <i class="fas fa-car text-primary me-1"></i>
                                                    <span class="small">@visitor.VehicleNumber</span>
