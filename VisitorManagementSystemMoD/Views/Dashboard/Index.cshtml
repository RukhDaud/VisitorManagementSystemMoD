                    @if (Model.CheckedOutVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Check-In</th>
                                        <th>Check-Out</th>
                                    </tr>
