                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Expected Time</th>
                                        <th>Vehicle</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.TodayVisitors)
                                    {
                                        <tr>
