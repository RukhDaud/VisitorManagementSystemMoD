                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-sign-out-alt fa-lg" style="color: #7c3aed;"></i>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <div class="d-flex gap-2">
                            <a href="javascript:void(0)" onclick="event.stopPropagation(); refreshCounts();" title="Refresh Counts" style="color: #7c3aed;">
                                <i class="fas fa-sync-alt"></i>
                            </a>
                            <div class="dropup" onclick="event.stopPropagation();">
                                <a href="javascript:void(0)" style="color: #7c3aed;" data-bs-toggle="dropdown" data-bs-auto-close="true" title="Generate Report">
                                    <i class="fas fa-file-alt"></i>
                                </a>
                                <ul class="dropdown-menu shadow" style="min-width: 160px;">
                                    <li><h6 class="dropdown-header">Check-Out Report</h6></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','today')"><i class="fas fa-calendar-day me-2"></i>Today</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','weekly')"><i class="fas fa-calendar-week me-2"></i>Weekly</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','monthly')"><i class="fas fa-calendar-alt me-2"></i>Monthly</a></li>
                                    <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedout','yearly')"><i class="fas fa-calendar me-2"></i>Yearly</a></li>
                                </ul>
                            </div>
                        </div>
                        <small style="color: #7c3aed; font-size: 0.75rem;">View Details →</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Today's Expected & Recent Activity KPI Cards (Modal Popup) -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%); border: 1px solid #d1d5db; cursor:pointer;" data-bs-toggle="modal" data-bs-target="#ExpectedTodayModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="fw-semibold mb-1 small" style="color: #374151;">Today's Expected</p>
                            <h4 class="fw-bold mb-0" style="color: #374151;">@Model.TodayVisitors.Count</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-calendar-day fa-lg" style="color: #374151;"></i>
                        </div>
                    </div>
                    <small class="mt-1 d-block" style="color: #374151; font-size: 0.75rem;">View today's expected visitors</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card kpi-card h-100 w-100" style="background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%); border: 1px solid #d1d5db; cursor:pointer;" data-bs-toggle="modal" data-bs-target="#RecentActivityModal">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="fw-semibold mb-1 small" style="color: #374151;">Recent Activity (Today)</p>
                            <h4 class="fw-bold mb-0" style="color: #374151;">@Model.RecentVisitors.Count</h4>
                        </div>
                        <div class="bg-white bg-opacity-50 rounded p-1">
                            <i class="fas fa-bolt fa-lg" style="color: #374151;"></i>
                        </div>
                    </div>
                    <small class="mt-1 d-block" style="color: #374151; font-size: 0.75rem;">View today's activity</small>
                </div>
            </div>
        </div>
    </div>


    }
