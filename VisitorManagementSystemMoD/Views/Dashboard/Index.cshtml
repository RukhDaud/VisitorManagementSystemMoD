    <!-- Reception Recent Activity Modal -->
    <div class="modal fade" id="RecRecentActivityModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
