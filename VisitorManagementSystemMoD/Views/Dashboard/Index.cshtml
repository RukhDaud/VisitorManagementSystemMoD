                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-users me-2"></i>
                                            <span class="small">User Management</span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-user-tag me-2"></i>
                                            <span class="small">Role Management</span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-building me-2"></i>
                                            <span class="small">Department Management</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <a asp-controller="Dashboard" asp-action="Administration" class="btn btn-sm px-4 py-2" style="background: #60a5fa; color: white; border: none; border-radius: 8px; font-size: 0.9rem;">
                                        <i class="fas fa-cogs me-2"></i>Administration Dashboard
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Audit Trail Card (Admin / SuperAdmin / Security Officer) -->
            <div class="col-12">
                <div class="card shadow-sm border-0" style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border: 1px solid #bae6fd !important;">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-9">
                                <h4 class="mb-2" style="color: #0369a1;">
                                    <i class="fas fa-clipboard-list me-2"></i>Visitor Audit Trail
                                </h4>
                                <p class="text-muted mb-2">
                                    View comprehensive visitor records with filters. Export reports as PDF, Excel, or print them directly.
                                </p>
                                <div class="d-flex gap-3 text-muted small">
                                    <span><i class="fas fa-file-pdf text-danger me-1"></i>PDF Export</span>
                                    <span><i class="fas fa-file-excel text-success me-1"></i>Excel Export</span>
                                    <span><i class="fas fa-print me-1"></i>Printable</span>
                                    <span><i class="fas fa-filter me-1"></i>Advanced Filters</span>
                                </div>
                            </div>
                            <div class="col-md-3 text-center">
                                <a asp-controller="Dashboard" asp-action="Audit" class="btn btn-sm px-4 py-2" style="background: #0284c7; color: white; border: none; border-radius: 8px; font-size: 0.9rem;">
                                    <i class="fas fa-clipboard-list me-2"></i>Open Audit Trail
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    }
    else if (userRole == "Reception")
    {
        <!-- Reception: no inline sections, all data in modals -->
    }
</div>

<!-- KPI Modals for Admin/Security Officer -->
@if (userRole == "Admin" || userRole == "SuperAdmin" || userRole == "Security Officer")
{
    <!-- Total Visitors Modal -->
    <div class="modal fade" id="TotalVisitorsModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-users me-2 text-primary"></i>Total Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.AllVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Expected Time</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.AllVisitorsList)
                                    {
                                        <tr>
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>
                                                @if (visitor.Status == "Pending")
                                                {
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                }
                                                else if (visitor.Status == "Approved")
                                                {
                                                    <span class="badge bg-success">Approved</span>
                                                }
                                                else if (visitor.Status == "Rejected")
                                                {
                                                    <span class="badge bg-danger">Rejected</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No visitors found</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: @Model.AllVisitorsList.Count visitor(s)</span>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Visitors Modal -->
    <div class="modal fade" id="PendingModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-clock me-2 text-warning"></i>Pending Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.PendingVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Expected Time</th>
                                        <th>Requested On</th>
                                        @if (userRole == "Security Officer")
                                        {
                                            <th class="text-center">Actions</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.PendingVisitorsList)
                                    {
                                        <tr id="pendingRow-@visitor.Id">
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>@visitor.RequestCreatedAt.ToString("MMM dd, h:mm tt")</td>
                                            @if (userRole == "Security Officer")
                                            {
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm">
                                                        <button type="button" class="btn btn-success btn-sm" onclick="approveVisitor(@visitor.Id, '@visitor.Name')" title="Approve">
                                                            <i class="fas fa-check me-1"></i>Approve
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" onclick="showRejectModal(@visitor.Id, '@visitor.Name')" title="Reject">
                                                            <i class="fas fa-times me-1"></i>Reject
                                                        </button>
                                                    </div>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No pending visitors</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: <span id="pendingTotalCount">@Model.PendingVisitorsList.Count</span> visitor(s)</span>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Rejection Reason Modal -->
    @if (userRole == "Security Officer")
    {
        <div class="modal fade" id="RejectReasonModal" tabindex="-1" style="z-index: 1060;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">
                            <i class="fas fa-times-circle me-2"></i>Reject Visitor
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="rejectVisitorId" />
                        <p class="mb-2">Rejecting visitor: <strong id="rejectVisitorName"></strong></p>
                        <div class="mb-3">
                            <label for="rejectionReason" class="form-label fw-semibold">Rejection Reason <span class="text-danger">*</span></label>
                            <textarea id="rejectionReason" class="form-control" rows="3" placeholder="Enter reason for rejection..." required></textarea>
                            <div class="invalid-feedback" id="rejectionReasonError">Rejection reason is required.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" onclick="confirmReject()">
                            <i class="fas fa-times me-1"></i>Confirm Rejection
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Approved Visitors Modal -->
    <div class="modal fade" id="ApprovedModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-check-circle me-2 text-success"></i>Approved Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.ApprovedVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Expected Time</th>
                                        <th>Approved By</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.ApprovedVisitorsList)
                                    {
                                        <tr>
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>@(visitor.ApprovedByName ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No approved visitors</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: @Model.ApprovedVisitorsList.Count visitor(s)</span>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Rejected Visitors Modal -->
    <div class="modal fade" id="RejectedModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-times-circle me-2 text-danger"></i>Rejected Visitors
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.RejectedVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Expected Time</th>
                                        <th>Rejection Reason</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.RejectedVisitorsList)
                                    {
                                        <tr>
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                            <td>@(visitor.RejectionReason ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No rejected visitors</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: @Model.RejectedVisitorsList.Count visitor(s)</span>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Checked In Visitors Modal -->
    <div class="modal fade" id="CheckedInModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-user-check me-2 text-success"></i>Checked In Visitors
                    </h5>
                    <div class="d-flex align-items-center gap-2 ms-auto me-2">
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="refreshCounts()" title="Refresh Counts">
                            <i class="fas fa-sync-alt me-1"></i>Refresh
                        </button>
                        <div class="dropdown">
                            <button type="button" class="btn btn-sm btn-success dropdown-toggle" data-bs-toggle="dropdown" data-bs-auto-close="true" title="Generate Report">
                                <i class="fas fa-file-alt me-1"></i>Report
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 160px;">
                                <li><h6 class="dropdown-header">Check-In Report</h6></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','today')"><i class="fas fa-calendar-day me-2"></i>Today</a></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','weekly')"><i class="fas fa-calendar-week me-2"></i>Weekly</a></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','monthly')"><i class="fas fa-calendar-alt me-2"></i>Monthly</a></li>
                                <li><a class="dropdown-item small" href="javascript:void(0)" onclick="generateReport('checkedin','yearly')"><i class="fas fa-calendar me-2"></i>Yearly</a></li>
                            </ul>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (Model.CheckedInVisitorsList.Any())
                    {
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-hover">
                                <thead class="table-light" style="position: sticky; top: 0;">
                                    <tr>
                                        <th>Name</th>
                                        <th>Host</th>
                                        <th>Purpose</th>
                                        <th>Check-In Time</th>
                                        <th>Vehicle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var visitor in Model.CheckedInVisitorsList)
                                    {
                                        <tr>
                                            <td><strong>@visitor.Name</strong></td>
                                            <td>@visitor.EmployeeName</td>
                                            <td>@visitor.Purpose</td>
                                            <td>@(visitor.CheckInTime?.ToString("MMM dd, h:mm tt") ?? "-")</td>
                                            <td>
                                                @if (visitor.HasVehicle)
                                                {
                                                    <i class="fas fa-car text-primary me-1"></i>
                                                    <span class="small">@visitor.VehicleNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">None</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">No visitors currently checked in</p>
                    }
                </div>
                <div class="modal-footer">
                    <span class="me-auto text-muted small">Total: @Model.CheckedInVisitorsList.Count visitor(s)</span>
                    <button type="button" class="btn btn-sm btn-success" onclick="exportModalExcel('CheckedInModal', 'CheckedIn_Visitors')"><i class="fas fa-file-excel me-1"></i>Excel</button>
                    <button type="button" class="btn btn-sm btn-danger" onclick="exportModalPdf('CheckedInModal', 'Checked In Visitors')"><i class="fas fa-file-pdf me-1"></i>PDF</button>
                    <button type="button" class="btn btn-sm btn-primary" onclick="printModal('CheckedInModal', 'Checked In Visitors')"><i class="fas fa-print me-1"></i>Print</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Checked Out Visitors Modal -->
    <div class="modal fade" id="CheckedOutModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
