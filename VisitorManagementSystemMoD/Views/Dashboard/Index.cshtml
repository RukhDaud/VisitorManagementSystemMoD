@section Scripts {
    <script src="~/lib/jspdf/jspdf.umd.min.js"></script>
    <script src="~/lib/jspdf-autotable/jspdf.plugin.autotable.min.js"></script>
    <script src="~/lib/sheetjs/xlsx.full.min.js"></script>
    <script>
        // Show Visitor Detail Modal
        function showVisitorDetail(id) {
            var modal = new bootstrap.Modal(document.getElementById('VisitorDetailModal'));
            $('#vdModalBody').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>');
            modal.show();

            $.get('@Url.Action("GetVisitorDetails", "Visitor")', { id: id }, function (res) {
                if (!res.success) {
                    $('#vdModalBody').html('<div class="alert alert-danger mb-0">Visitor not found.</div>');
                    return;
                }
                var d = res.data;
                var statusBadge = d.status === 'Approved' ? '<span class="badge bg-success">Approved</span>' :
                    d.status === 'Rejected' ? '<span class="badge bg-danger">Rejected</span>' :
                    '<span class="badge bg-warning text-dark">Pending</span>';
                if (d.checkOutTime) statusBadge = '<span class="badge bg-secondary">Checked Out</span>';
                else if (d.checkInTime) statusBadge = '<span class="badge bg-success">Checked In</span>';

                var urgentBadge = d.isUrgent ? ' <span class="badge bg-danger"><i class="fas fa-bolt me-1"></i>Urgent</span>' : '';

                var html = '<div class="row g-3">';
                // Visitor Info
                html += '<div class="col-md-6"><div class="card h-100"><div class="card-header py-2 bg-primary bg-opacity-10"><h6 class="mb-0 fw-semibold small"><i class="fas fa-user me-2 text-primary"></i>Visitor Information</h6></div>';
                html += '<div class="card-body p-3">';
                html += '<div class="mb-2"><span class="text-muted small d-block">Full Name</span><strong>' + d.name + '</strong>' + urgentBadge + '</div>';
                html += '<div class="mb-2"><span class="text-muted small d-block">CNIC</span>' + (d.cnic || '<span class="text-muted">Not provided</span>') + '</div>';
                html += '<div class="mb-2"><span class="text-muted small d-block">Phone</span>' + (d.phone || '<span class="text-muted">Not provided</span>') + '</div>';
                html += '<div class="mb-0"><span class="text-muted small d-block">Status</span>' + statusBadge + '</div>';
                html += '</div></div></div>';

                // Visit Details
                html += '<div class="col-md-6"><div class="card h-100"><div class="card-header py-2 bg-info bg-opacity-10"><h6 class="mb-0 fw-semibold small"><i class="fas fa-info-circle me-2 text-info"></i>Visit Details</h6></div>';
                html += '<div class="card-body p-3">';
                html += '<div class="mb-2"><span class="text-muted small d-block">Purpose</span>' + (d.purpose || '<span class="text-muted">Not provided</span>') + '</div>';
                html += '<div class="mb-2"><span class="text-muted small d-block">Destination</span>' + d.departmentName + '</div>';
                html += '<div class="mb-2"><span class="text-muted small d-block">Expected Time</span>' + d.expectedTime + '</div>';
                html += '<div class="mb-0"><span class="text-muted small d-block">Requested On</span>' + d.requestCreatedAt + '</div>';
                html += '</div></div></div>';

                // Host & Approval
                html += '<div class="col-md-6"><div class="card h-100"><div class="card-header py-2 bg-success bg-opacity-10"><h6 class="mb-0 fw-semibold small"><i class="fas fa-user-tie me-2 text-success"></i>Host & Approval</h6></div>';
                html += '<div class="card-body p-3">';
                html += '<div class="mb-2"><span class="text-muted small d-block">Host (Employee)</span>' + d.employeeName + '</div>';
                html += '<div class="mb-2"><span class="text-muted small d-block">Approved By</span>' + d.approvedByName + '</div>';
                html += '<div class="mb-0"><span class="text-muted small d-block">Approved At</span>' + d.approvedAt + '</div>';
                if (d.rejectionReason) {
                    html += '<div class="mt-2"><span class="text-muted small d-block">Rejection Reason</span><span class="text-danger">' + d.rejectionReason + '</span></div>';
                }
                html += '</div></div></div>';

                // Vehicle & Check-In/Out
                html += '<div class="col-md-6"><div class="card h-100"><div class="card-header py-2 bg-warning bg-opacity-10"><h6 class="mb-0 fw-semibold small"><i class="fas fa-clock me-2 text-warning"></i>Vehicle & Activity</h6></div>';
                html += '<div class="card-body p-3">';
                if (d.hasVehicle) {
                    html += '<div class="mb-2"><span class="text-muted small d-block">Vehicle</span><i class="fas fa-car text-primary me-1"></i>' + (d.vehicleType || '') + ' — ' + (d.vehicleNumber || 'N/A') + '</div>';
                } else {
                    html += '<div class="mb-2"><span class="text-muted small d-block">Vehicle</span><span class="text-muted">No vehicle</span></div>';
                }
                html += '<div class="mb-2"><span class="text-muted small d-block">Check-In Time</span>' + (d.checkInTime || '<span class="text-muted">Not checked in</span>') + '</div>';
                html += '<div class="mb-0"><span class="text-muted small d-block">Check-Out Time</span>' + (d.checkOutTime || '<span class="text-muted">Not checked out</span>') + '</div>';
                html += '</div></div></div>';

                html += '</div>';

                $('#vdTitle').text(d.name + ' — Visitor Details');
                $('#vdModalBody').html(html);
            }).fail(function () {
                $('#vdModalBody').html('<div class="alert alert-danger mb-0">Error loading visitor details.</div>');
            });
        }

        // Refresh counts function
        function refreshCounts() {
            $.get('@Url.Action("RefreshCounts", "Dashboard")', function (response) {
                if (response.success) {
                    $('#checkedInCount').text(response.checkedIn);
                    $('#checkedOutCount').text(response.checkedOut);

                    // Show success notification
                    showToast('Counts refreshed successfully!', 'success');
                }
            });
        }

        // Generate report function
        function generateReport(type, period) {
            $('#reportModal').modal('show');
            
            $.get('@Url.Action("GenerateReport", "Dashboard")', {
                type: type,
                period: period
            }, function (response) {
                if (response.success) {
                    displayReport(response);
                } else {
                    $('#reportContent').html('<div class="alert alert-danger">Error generating report</div>');
                }
            });
        }

        var lastReportData = null;

        // Display report function
        function displayReport(data) {
            lastReportData = data;
            const typeLabel = data.type === 'checkedin' ? 'Check-In' : 'Check-Out';
            const periodLabel = data.period.charAt(0).toUpperCase() + data.period.slice(1);
            
            let html = `
                <div class="report-header mb-4">
                    <h4>${typeLabel} Report - ${periodLabel}</h4>
                    <p class="text-muted">Period: ${data.startDate} - ${data.endDate}</p>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Total ${typeLabel}s</h5>
                                    <h2 class="text-primary mb-0">${data.totalCount}</h2>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Late Checkouts (After 7 PM)</h5>
                                    <h2 class="text-danger mb-0">${data.lateCheckouts}</h2>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>CNIC</th>
                                <th>Purpose</th>
                                <th>Host</th>
                                <th>Department</th>
                                <th>Check-In</th>
                                <th>Check-Out</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

            data.data.forEach(visitor => {
                const lateClass = visitor.isLateCheckout ? 'table-warning' : '';
                html += `
                    <tr class="${lateClass}">
                        <td>${visitor.name}</td>
                        <td>${visitor.cnic || 'N/A'}</td>
                        <td>${visitor.purpose}</td>
                        <td>${visitor.employeeName}</td>
                        <td>${visitor.departmentName}</td>
                        <td>${visitor.checkInTime}</td>
                        <td>${visitor.checkOutTime}</td>
                        <td>
                            ${visitor.isLateCheckout ? 
                                '<span class="badge bg-warning">Late Checkout</span>' : 
                                '<span class="badge bg-success">Normal</span>'}
                        </td>
                    </tr>
                `;
            });

            html += `
                        </tbody>
                    </table>
                </div>
            `;

            $('#reportContent').html(html);
        }

        // Toast notification
        function showToast(message, type) {
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const icon = type === 'success' ? 'check' : 'exclamation';
            const toast = $(`
                <div class="alert ${alertClass} alert-dismissible fade show position-fixed top-0 end-0 m-3" role="alert" style="z-index: 9999;">
                    <i class="fas fa-${icon}-circle me-2"></i>${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);
            $('body').append(toast);
            setTimeout(() => toast.alert('close'), 3000);
        }

        // Filter Today's Visitors by vehicle status
        function filterTodayVisitors() {
            const filterValue = document.getElementById('todayVisitorsFilter').value;
            const items = document.querySelectorAll('#todayVisitorsList .visitor-item');

            items.forEach(item => {
                const hasVehicle = item.getAttribute('data-has-vehicle') === 'true';

                if (filterValue === 'all') {
                    item.style.display = '';
                } else if (filterValue === 'with-vehicle' && hasVehicle) {
                    item.style.display = '';
                } else if (filterValue === 'without-vehicle' && !hasVehicle) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        // Filter Recent Activity by search text (Admin/Security Officer)
        function filterRecentActivity() {
            const searchText = document.getElementById('recentActivitySearch').value.toLowerCase();
            const items = document.querySelectorAll('#recentActivityList .recent-activity-item');
            let visibleCount = 0;

            items.forEach(item => {
                const name = item.getAttribute('data-name');
                const purpose = item.getAttribute('data-purpose');
                const host = item.getAttribute('data-host');

                if (name.includes(searchText) || purpose.includes(searchText) || host.includes(searchText)) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            document.getElementById('recentActivityCount').textContent = visibleCount;
        }

        // Filter Recent Activity by search text (Employee)
        function filterEmployeeRecentActivity() {
            const searchText = document.getElementById('employeeRecentActivitySearch').value.toLowerCase();
            const items = document.querySelectorAll('#employeeRecentActivityList .employee-recent-activity-item');
            let visibleCount = 0;

            items.forEach(item => {
                const name = item.getAttribute('data-name');
                const purpose = item.getAttribute('data-purpose');
                const host = item.getAttribute('data-host');

                if (name.includes(searchText) || purpose.includes(searchText) || host.includes(searchText)) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            document.getElementById('employeeRecentActivityCount').textContent = visibleCount;
        }

        // Approve visitor from Pending modal
        function approveVisitor(id, name) {
            if (!confirm('Approve visitor "' + name + '"?')) return;
            $.ajax({
                url: '@Url.Action("Approve", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id }),
                success: function (res) {
                    if (res.success) {
                        $('#pendingRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#PendingModal tbody tr:visible').length;
                            $('#pendingTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#PendingModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No pending visitors</p>'
                                );
                            }
                        });
                        showToast('Visitor "' + name + '" approved successfully!', 'success');
                    } else {
                        showToast(res.message || 'Failed to approve visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error approving visitor. Please try again.', 'error');
                }
            });
        }

        // Show rejection reason modal
        function showRejectModal(id, name) {
            $('#rejectVisitorId').val(id);
            $('#rejectVisitorName').text(name);
            $('#rejectionReason').val('').removeClass('is-invalid');
            var rejectModal = new bootstrap.Modal(document.getElementById('RejectReasonModal'));
            rejectModal.show();
        }

        // Confirm rejection with reason
        function confirmReject() {
            var id = parseInt($('#rejectVisitorId').val());
            var reason = $('#rejectionReason').val().trim();
            var name = $('#rejectVisitorName').text();

            if (!reason) {
                $('#rejectionReason').addClass('is-invalid');
                return;
            }
            $('#rejectionReason').removeClass('is-invalid');

            $.ajax({
                url: '@Url.Action("Reject", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id, reason: reason }),
                success: function (res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('RejectReasonModal')).hide();
                        $('#pendingRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#PendingModal tbody tr:visible').length;
                            $('#pendingTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#PendingModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No pending visitors</p>'
                                );
                            }
                        });
                        showToast('Visitor "' + name + '" rejected.', 'success');
                    } else {
                        showToast(res.message || 'Failed to reject visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error rejecting visitor. Please try again.', 'error');
                }
            });
        }

        // Check in visitor from Reception Awaiting Entry modal
        function checkInVisitor(id, name) {
            if (!confirm('Check in visitor "' + name + '"?')) return;
            var cnic = $('#dashCnic-' + id).val() || '';
            $.ajax({
                url: '@Url.Action("CheckIn", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id, cnic: cnic.trim() }),
                success: function (res) {
                    if (res.success) {
                        $('#awaitingRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#RecAwaitingModal tbody tr:visible').length;
                            $('#awaitingTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#RecAwaitingModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No visitors awaiting entry</p>'
                                );
                            }
                        });
                        // Update KPI card counts
                        var awaitingCard = $('#recCheckedInCount');
                        if (awaitingCard.length) {
                            awaitingCard.text(parseInt(awaitingCard.text()) + 1);
                        }
                        showToast('Visitor "' + name + '" checked in successfully!', 'success');
                    } else {
                        showToast(res.message || 'Failed to check in visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error checking in visitor. Please try again.', 'error');
                }
            });
        }

        // Check out visitor from Reception Inside modal
        function checkOutVisitor(id, name) {
            if (!confirm('Check out visitor "' + name + '"?')) return;
            $.ajax({
                url: '@Url.Action("CheckOut", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
