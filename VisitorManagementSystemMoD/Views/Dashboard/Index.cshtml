}

<!-- Report Modal -->
<div class="modal fade" id="reportModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-file-alt me-2"></i>Visitor Report
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="reportContent">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3">Generating report...</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="exportReportExcel()">
                    <i class="fas fa-file-excel me-1"></i>Excel
                </button>
                <button type="button" class="btn btn-danger" onclick="exportReportPdf()">
                    <i class="fas fa-file-pdf me-1"></i>PDF
                </button>
                <button type="button" class="btn btn-primary" onclick="printReport()">
                    <i class="fas fa-print me-1"></i>Print
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jspdf/jspdf.umd.min.js"></script>
    <script src="~/lib/jspdf-autotable/jspdf.plugin.autotable.min.js"></script>
    <script src="~/lib/sheetjs/xlsx.full.min.js"></script>
    <script>
        // Refresh counts function
        function refreshCounts() {
            $.get('@Url.Action("RefreshCounts", "Dashboard")', function (response) {
                if (response.success) {
                    $('#checkedInCount').text(response.checkedIn);
                    $('#checkedOutCount').text(response.checkedOut);

                    // Show success notification
                    showToast('Counts refreshed successfully!', 'success');
                }
            });
        }

        // Generate report function
        function generateReport(type, period) {
            $('#reportModal').modal('show');
            
            $.get('@Url.Action("GenerateReport", "Dashboard")', {
                type: type,
                period: period
            }, function (response) {
                if (response.success) {
                    displayReport(response);
                } else {
                    $('#reportContent').html('<div class="alert alert-danger">Error generating report</div>');
                }
            });
        }

        var lastReportData = null;

        // Display report function
        function displayReport(data) {
            lastReportData = data;
            const typeLabel = data.type === 'checkedin' ? 'Check-In' : 'Check-Out';
            const periodLabel = data.period.charAt(0).toUpperCase() + data.period.slice(1);
            
            let html = `
                <div class="report-header mb-4">
                    <h4>${typeLabel} Report - ${periodLabel}</h4>
                    <p class="text-muted">Period: ${data.startDate} - ${data.endDate}</p>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Total ${typeLabel}s</h5>
                                    <h2 class="text-primary mb-0">${data.totalCount}</h2>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h5 class="card-title">Late Checkouts (After 7 PM)</h5>
                                    <h2 class="text-danger mb-0">${data.lateCheckouts}</h2>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>CNIC</th>
                                <th>Purpose</th>
                                <th>Host</th>
                                <th>Department</th>
                                <th>Check-In</th>
                                <th>Check-Out</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

            data.data.forEach(visitor => {
                const lateClass = visitor.isLateCheckout ? 'table-warning' : '';
                html += `
                    <tr class="${lateClass}">
                        <td>${visitor.name}</td>
                        <td>${visitor.cnic || 'N/A'}</td>
                        <td>${visitor.purpose}</td>
                        <td>${visitor.employeeName}</td>
                        <td>${visitor.departmentName}</td>
                        <td>${visitor.checkInTime}</td>
                        <td>${visitor.checkOutTime}</td>
                        <td>
                            ${visitor.isLateCheckout ? 
                                '<span class="badge bg-warning">Late Checkout</span>' : 
                                '<span class="badge bg-success">Normal</span>'}
                        </td>
                    </tr>
                `;
            });

            html += `
                        </tbody>
                    </table>
                </div>
            `;

            $('#reportContent').html(html);
        }

        // Toast notification
        function showToast(message, type) {
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const icon = type === 'success' ? 'check' : 'exclamation';
            const toast = $(`
                <div class="alert ${alertClass} alert-dismissible fade show position-fixed top-0 end-0 m-3" role="alert" style="z-index: 9999;">
                    <i class="fas fa-${icon}-circle me-2"></i>${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);
            $('body').append(toast);
            setTimeout(() => toast.alert('close'), 3000);
        }

        // Filter Today's Visitors by vehicle status
        function filterTodayVisitors() {
            const filterValue = document.getElementById('todayVisitorsFilter').value;
            const items = document.querySelectorAll('#todayVisitorsList .visitor-item');

            items.forEach(item => {
                const hasVehicle = item.getAttribute('data-has-vehicle') === 'true';

                if (filterValue === 'all') {
                    item.style.display = '';
                } else if (filterValue === 'with-vehicle' && hasVehicle) {
                    item.style.display = '';
                } else if (filterValue === 'without-vehicle' && !hasVehicle) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        // Filter Recent Activity by search text (Admin/Security Officer)
        function filterRecentActivity() {
            const searchText = document.getElementById('recentActivitySearch').value.toLowerCase();
            const items = document.querySelectorAll('#recentActivityList .recent-activity-item');
            let visibleCount = 0;

            items.forEach(item => {
                const name = item.getAttribute('data-name');
                const purpose = item.getAttribute('data-purpose');
                const host = item.getAttribute('data-host');

                if (name.includes(searchText) || purpose.includes(searchText) || host.includes(searchText)) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            document.getElementById('recentActivityCount').textContent = visibleCount;
        }

        // Filter Recent Activity by search text (Employee)
        function filterEmployeeRecentActivity() {
            const searchText = document.getElementById('employeeRecentActivitySearch').value.toLowerCase();
            const items = document.querySelectorAll('#employeeRecentActivityList .employee-recent-activity-item');
            let visibleCount = 0;

            items.forEach(item => {
                const name = item.getAttribute('data-name');
                const purpose = item.getAttribute('data-purpose');
                const host = item.getAttribute('data-host');

                if (name.includes(searchText) || purpose.includes(searchText) || host.includes(searchText)) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            document.getElementById('employeeRecentActivityCount').textContent = visibleCount;
        }

        // Approve visitor from Pending modal
        function approveVisitor(id, name) {
            if (!confirm('Approve visitor "' + name + '"?')) return;
            $.ajax({
                url: '@Url.Action("Approve", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id }),
                success: function (res) {
                    if (res.success) {
                        $('#pendingRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#PendingModal tbody tr:visible').length;
                            $('#pendingTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#PendingModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No pending visitors</p>'
                                );
                            }
                        });
                        showToast('Visitor "' + name + '" approved successfully!', 'success');
                    } else {
                        showToast(res.message || 'Failed to approve visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error approving visitor. Please try again.', 'error');
                }
            });
        }

        // Show rejection reason modal
        function showRejectModal(id, name) {
            $('#rejectVisitorId').val(id);
            $('#rejectVisitorName').text(name);
            $('#rejectionReason').val('').removeClass('is-invalid');
            var rejectModal = new bootstrap.Modal(document.getElementById('RejectReasonModal'));
            rejectModal.show();
        }

        // Confirm rejection with reason
        function confirmReject() {
            var id = parseInt($('#rejectVisitorId').val());
            var reason = $('#rejectionReason').val().trim();
            var name = $('#rejectVisitorName').text();

            if (!reason) {
                $('#rejectionReason').addClass('is-invalid');
                return;
            }
            $('#rejectionReason').removeClass('is-invalid');

            $.ajax({
                url: '@Url.Action("Reject", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id, reason: reason }),
                success: function (res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('RejectReasonModal')).hide();
                        $('#pendingRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#PendingModal tbody tr:visible').length;
                            $('#pendingTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#PendingModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No pending visitors</p>'
                                );
                            }
                        });
                        showToast('Visitor "' + name + '" rejected.', 'success');
                    } else {
                        showToast(res.message || 'Failed to reject visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error rejecting visitor. Please try again.', 'error');
                }
            });
        }

        // Check in visitor from Reception Awaiting Entry modal
        function checkInVisitor(id, name) {
            if (!confirm('Check in visitor "' + name + '"?')) return;
            $.ajax({
                url: '@Url.Action("CheckIn", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id }),
                success: function (res) {
                    if (res.success) {
                        $('#awaitingRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#RecAwaitingModal tbody tr:visible').length;
                            $('#awaitingTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#RecAwaitingModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No visitors awaiting entry</p>'
                                );
                            }
                        });
                        // Update KPI card counts
                        var awaitingCard = $('#recCheckedInCount');
                        if (awaitingCard.length) {
                            awaitingCard.text(parseInt(awaitingCard.text()) + 1);
                        }
                        showToast('Visitor "' + name + '" checked in successfully!', 'success');
                    } else {
                        showToast(res.message || 'Failed to check in visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error checking in visitor. Please try again.', 'error');
                }
            });
        }

        // Check out visitor from Reception Inside modal
        function checkOutVisitor(id, name) {
            if (!confirm('Check out visitor "' + name + '"?')) return;
            $.ajax({
                url: '@Url.Action("CheckOut", "Visitor")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ id: id }),
                success: function (res) {
                    if (res.success) {
                        $('#insideRow-' + id).fadeOut(300, function () {
                            $(this).remove();
                            var remaining = $('#RecCheckedInModal tbody tr:visible').length;
                            $('#insideTotalCount').text(remaining);
                            if (remaining === 0) {
                                $('#RecCheckedInModal .table-responsive').replaceWith(
                                    '<p class="text-muted text-center py-4 mb-0">No visitors currently inside</p>'
                                );
                            }
                        });
                        // Update KPI card counts
                        var checkedOutCard = $('#recCheckedOutCount');
                        if (checkedOutCard.length) {
                            checkedOutCard.text(parseInt(checkedOutCard.text()) + 1);
                        }
                        showToast('Visitor "' + name + '" checked out successfully!', 'success');
                    } else {
                        showToast(res.message || 'Failed to check out visitor', 'error');
                    }
                },
                error: function () {
                    showToast('Error checking out visitor. Please try again.', 'error');
                }
            });
        }

        // --- Export functions for Report Modal ---
        function exportReportExcel() {
            if (!lastReportData || !lastReportData.data || !lastReportData.data.length) { alert('No report data to export.'); return; }
            var headers = ['Name', 'CNIC', 'Purpose', 'Host', 'Department', 'Check-In', 'Check-Out', 'Status'];
            var rows = lastReportData.data.map(function(v) {
                return [v.name, v.cnic, v.purpose, v.employeeName, v.departmentName, v.checkInTime, v.checkOutTime, v.isLateCheckout ? 'Late Checkout' : 'Normal'];
            });
            rows.unshift(headers);
            var ws = XLSX.utils.aoa_to_sheet(rows);
            var wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Report');
            ws['!cols'] = headers.map(function() { return { wch: 20 }; });
            XLSX.writeFile(wb, 'Visitor_Report_' + new Date().toISOString().slice(0,10) + '.xlsx');
        }

        function exportReportPdf() {
            if (!lastReportData || !lastReportData.data || !lastReportData.data.length) { alert('No report data to export.'); return; }
            var { jsPDF } = window.jspdf;
            var doc = new jsPDF('landscape', 'mm', 'a4');
            var typeLabel = lastReportData.type === 'checkedin' ? 'Check-In' : 'Check-Out';
            doc.setFontSize(16);
            doc.text(typeLabel + ' Report - ' + lastReportData.period, 14, 15);
            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text('Period: ' + lastReportData.startDate + ' - ' + lastReportData.endDate, 14, 22);
            var headers = ['Name', 'CNIC', 'Purpose', 'Host', 'Department', 'Check-In', 'Check-Out', 'Status'];
            var rows = lastReportData.data.map(function(v) {
                return [v.name, v.cnic, v.purpose, v.employeeName, v.departmentName, v.checkInTime, v.checkOutTime, v.isLateCheckout ? 'Late Checkout' : 'Normal'];
            });
            doc.autoTable({ head: [headers], body: rows, startY: 27, styles: { fontSize: 7, cellPadding: 2 }, headStyles: { fillColor: [59, 130, 246], textColor: 255 }, alternateRowStyles: { fillColor: [248, 249, 250] }, margin: { left: 14, right: 14 } });
            doc.save('Visitor_Report_' + new Date().toISOString().slice(0,10) + '.pdf');
        }

        function printReport() {
            if (!lastReportData || !lastReportData.data || !lastReportData.data.length) { alert('No report data to print.'); return; }
            var content = document.getElementById('reportContent').innerHTML;
            var printWin = window.open('', '_blank');
            printWin.document.write('<!DOCTYPE html><html><head><title>Visitor Report<' + '/title>');
            printWin.document.write('<style>body{font-family:Arial,sans-serif;margin:20px;}table{width:100%;border-collapse:collapse;font-size:11px;}th,td{border:1px solid #ddd;padding:6px 8px;text-align:left;}th{background:#3b82f6;color:#fff;}.badge{padding:2px 6px;border-radius:4px;font-size:9px;}.bg-warning{background:#f59e0b;}.bg-success{background:#10b981;color:#fff;}<' + '/style>');
            printWin.document.write('<' + '/head><body>');
            printWin.document.write(content);
            printWin.document.write('<' + '/body><' + '/html>');
            printWin.document.close();
            printWin.onload = function() { printWin.print(); };
        }

        // --- Export functions for Modal tables (CheckedIn/CheckedOut) ---
        function exportModalExcel(modalId, filename) {
            var table = document.querySelector('#' + modalId + ' table');
            if (!table) { alert('No data to export.'); return; }
            var wb = XLSX.utils.table_to_book(table, { sheet: 'Data' });
            XLSX.writeFile(wb, filename + '_' + new Date().toISOString().slice(0,10) + '.xlsx');
        }

        function exportModalPdf(modalId, title) {
            var table = document.querySelector('#' + modalId + ' table');
            if (!table) { alert('No data to export.'); return; }
            var { jsPDF } = window.jspdf;
            var doc = new jsPDF('landscape', 'mm', 'a4');
            doc.setFontSize(16);
            doc.text(title, 14, 15);
            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);
            var headers = [];
            var rows = [];
            table.querySelectorAll('thead th').forEach(function(th) { headers.push(th.textContent.trim()); });
            table.querySelectorAll('tbody tr').forEach(function(tr) {
                var row = [];
                tr.querySelectorAll('td').forEach(function(td) { row.push(td.textContent.trim()); });
                if (row.length) rows.push(row);
            });
            doc.autoTable({ head: [headers], body: rows, startY: 27, styles: { fontSize: 7, cellPadding: 2 }, headStyles: { fillColor: [59, 130, 246], textColor: 255 }, alternateRowStyles: { fillColor: [248, 249, 250] }, margin: { left: 14, right: 14 } });
            doc.save(title.replace(/\s+/g, '_') + '_' + new Date().toISOString().slice(0,10) + '.pdf');
        }

        function printModal(modalId, title) {
            var table = document.querySelector('#' + modalId + ' table');
            if (!table) { alert('No data to print.'); return; }
            var printWin = window.open('', '_blank');
            printWin.document.write('<!DOCTYPE html><html><head><title>' + title + '<' + '/title>');
            printWin.document.write('<style>body{font-family:Arial,sans-serif;margin:20px;}table{width:100%;border-collapse:collapse;font-size:11px;}th,td{border:1px solid #ddd;padding:6px 8px;text-align:left;}th{background:#3b82f6;color:#fff;}h2{margin-bottom:4px;}p{color:#666;margin-top:0;}<' + '/style>');
            printWin.document.write('<' + '/head><body>');
            printWin.document.write('<h2>' + title + '<' + '/h2>');
            printWin.document.write('<p>Generated: ' + new Date().toLocaleString() + '<' + '/p>');
            printWin.document.write(table.outerHTML);
            printWin.document.write('<' + '/body><' + '/html>');
            printWin.document.close();
            printWin.onload = function() { printWin.print(); };
        }
        </script>

