@{
    ViewData["Title"] = "Audit Trail";
    var userRole = ViewBag.UserRole as string;
    var departments = ViewBag.Departments as List<VisitorManagementSystemMoD.Models.Department>;
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")"><i class="fas fa-home"></i> Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page"><i class="fas fa-clipboard-list"></i> Audit Trail</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="fas fa-clipboard-list me-2 text-primary"></i>Visitor Audit Trail</h2>
        <p class="text-muted mb-0">Comprehensive record of all visitor activities</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-success btn-sm" onclick="exportExcel()">
            <i class="fas fa-file-excel me-1"></i>Excel
        </button>
        <button class="btn btn-danger btn-sm" onclick="exportPdf()">
            <i class="fas fa-file-pdf me-1"></i>PDF
        </button>
        <button class="btn btn-secondary btn-sm" onclick="printAudit()">
            <i class="fas fa-print me-1"></i>Print
        </button>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Search</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="auditSearch" class="form-control" placeholder="Name, CNIC, Host, Purpose...">
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Status</label>
                <select id="auditStatus" class="form-select form-select-sm">
                    <option value="all">All Statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                    <option value="CheckedIn">Checked In</option>
                    <option value="CheckedOut">Checked Out</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">Department</label>
                <select id="auditDepartment" class="form-select form-select-sm">
                    <option value="0">All Departments</option>
                    @if (departments != null)
                    {
                        @foreach (var dept in departments)
                        {
                            <option value="@dept.Id">@dept.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">From</label>
                <input type="date" id="auditDateFrom" class="form-control form-control-sm">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold mb-1">To</label>
                <input type="date" id="auditDateTo" class="form-control form-control-sm">
            </div>
            <div class="col-md-1 d-flex gap-1">
                <button class="btn btn-outline-secondary btn-sm flex-fill" onclick="resetFilters()" title="Reset Filters">
                    <i class="fas fa-undo"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- HP Filter -->
<div class="mb-3" id="hpFilterBar" style="display:none;">
    <div class="alert alert-danger d-flex align-items-center justify-content-between py-2 mb-0 border-danger" style="background: linear-gradient(135deg, #fff5f5, #ffe3e3);">
        <div>
            <i class="fas fa-bolt text-danger me-2"></i>
            <strong id="hpCountText">0</strong> <span class="text-danger fw-semibold">High Priority</span> visitor(s) found
        </div>
        <button class="btn btn-outline-danger btn-sm" id="hpToggleBtn" onclick="toggleHpFilter()">
            <i class="fas fa-filter me-1"></i>Show High Priority Only
        </button>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4" id="auditSummary">
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="card-body p-2">
                <p class="text-muted small mb-0">Total Records</p>
                <h4 class="fw-bold mb-0 text-primary" id="summaryTotal">0</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2" style="border-left: 3px solid #dc3545 !important;">
            <div class="card-body p-2">
                <p class="text-muted small mb-0"><i class="fas fa-bolt text-danger me-1"></i>High Priority</p>
                <h4 class="fw-bold mb-0 text-danger" id="summaryHP">0</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="card-body p-2">
                <p class="text-muted small mb-0">Pending</p>
                <h4 class="fw-bold mb-0 text-warning" id="summaryPending">0</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="card-body p-2">
                <p class="text-muted small mb-0">Approved</p>
                <h4 class="fw-bold mb-0 text-success" id="summaryApproved">0</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="card-body p-2">
                <p class="text-muted small mb-0">Rejected</p>
                <h4 class="fw-bold mb-0 text-danger" id="summaryRejected">0</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="card-body p-2">
                <p class="text-muted small mb-0">Checked In</p>
                <h4 class="fw-bold mb-0" style="color: #10b981;" id="summaryCheckedIn">0</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="card-body p-2">
                <p class="text-muted small mb-0">Checked Out</p>
                <h4 class="fw-bold mb-0" style="color: #7c3aed;" id="summaryCheckedOut">0</h4>
            </div>
        </div>
    </div>
</div>

<!-- Audit Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive" id="auditTableContainer">
            <table class="table table-hover mb-0" id="auditTable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                    <tr class="small">
                        <th class="px-3 py-2">#</th>
                        <th class="px-3 py-2">Visitor Name</th>
                        <th class="px-3 py-2">CNIC</th>
                        <th class="px-3 py-2">Phone</th>
                        <th class="px-3 py-2">Purpose</th>
                        <th class="px-3 py-2">Host</th>
                        <th class="px-3 py-2">Department</th>
                        <th class="px-3 py-2">Expected</th>
                        <th class="px-3 py-2">Status</th>
                        <th class="px-3 py-2">Approved By</th>
                        <th class="px-3 py-2">Check-In</th>
                        <th class="px-3 py-2">Check-Out</th>
                        <th class="px-3 py-2">Vehicle</th>
                        <th class="px-3 py-2">Requested</th>
                    </tr>
                </thead>
                <tbody id="auditTableBody" class="small">
                    <tr>
                        <td colspan="14" class="text-center py-5 text-muted">
                            <i class="fas fa-spinner fa-spin fa-2x mb-3 d-block"></i>
                            Loading audit data...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top d-flex justify-content-between align-items-center py-2">
        <span class="text-muted small" id="auditRecordCount">Loading...</span>
        <span class="text-muted small">Generated: @DateTime.Now.ToString("MMM dd, yyyy hh:mm tt")</span>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jspdf/jspdf.umd.min.js"></script>
    <script src="~/lib/jspdf-autotable/jspdf.plugin.autotable.min.js"></script>
    <script src="~/lib/sheetjs/xlsx.full.min.js"></script>
    <script>
        var auditData = [];
        var debounceTimer;
        var hpFilterActive = false;

        function loadAuditData() {
            var params = {
                search: $('#auditSearch').val(),
                status: $('#auditStatus').val(),
                departmentId: $('#auditDepartment').val(),
                dateFrom: $('#auditDateFrom').val(),
                dateTo: $('#auditDateTo').val()
            };

            $('#auditTableBody').html('<tr><td colspan="14" class="text-center py-5 text-muted"><i class="fas fa-spinner fa-spin fa-2x mb-3 d-block"></i>Loading...</td></tr>');

            $.get('@Url.Action("GetAuditData", "Dashboard")', params, function (res) {
                if (!res.success) return;

                auditData = res.data;
                renderTable(auditData);
                updateSummary(auditData);
                $('#auditRecordCount').text('Showing ' + res.totalCount + ' record(s)');

                if (hpFilterActive) {
                    $('#auditTableBody tr[data-hp]').each(function () {
                        $(this).toggle($(this).data('hp') === true);
                    });
                }
            }).fail(function () {
                $('#auditTableBody').html('<tr><td colspan="14" class="text-center py-5 text-danger"><i class="fas fa-exclamation-triangle fa-2x mb-3 d-block"></i>Failed to load audit data. Please try again.</td></tr>');
                $('#auditRecordCount').text('Error loading data');
            });
        }

        function renderTable(data) {
            if (data.length === 0) {
                $('#auditTableBody').html('<tr><td colspan="14" class="text-center py-5 text-muted"><i class="fas fa-search fa-2x mb-3 d-block" style="color:#d1d5db;"></i>No records found matching your filters</td></tr>');
                return;
            }

            var html = '';
            data.forEach(function (v, i) {
                var statusBadge = '';
                switch (v.status) {
                    case 'Pending': statusBadge = '<span class="badge bg-warning text-dark">Pending</span>'; break;
                    case 'Approved': statusBadge = '<span class="badge bg-success">Approved</span>'; break;
                    case 'Rejected': statusBadge = '<span class="badge bg-danger">Rejected</span>'; break;
                    case 'Checked In': statusBadge = '<span class="badge" style="background:#10b981;">Checked In</span>'; break;
                    case 'Checked Out': statusBadge = '<span class="badge" style="background:#7c3aed;">Checked Out</span>'; break;
                    default: statusBadge = '<span class="badge bg-secondary">' + v.status + '</span>'; break;
                }

                var hpBadge = v.isUrgent ? ' <span class="badge bg-danger" style="font-size:0.65rem;"><i class="fas fa-bolt me-1"></i>High Priority</span>' : '';
                var rowStyle = v.isUrgent ? ' style="border-left: 3px solid #dc3545; background-color: #fff5f5;"' : '';

                html += '<tr data-hp="' + (v.isUrgent ? 'true' : 'false') + '"' + rowStyle + '>' +
                    '<td class="px-3 py-2 text-muted">' + (i + 1) + '</td>' +
                    '<td class="px-3 py-2 fw-semibold">' + v.name + hpBadge + '</td>' +
                    '<td class="px-3 py-2">' + v.cnic + '</td>' +
                    '<td class="px-3 py-2">' + v.phone + '</td>' +
                    '<td class="px-3 py-2">' + v.purpose + '</td>' +
                    '<td class="px-3 py-2">' + v.employeeName + '</td>' +
                    '<td class="px-3 py-2">' + v.departmentName + '</td>' +
                    '<td class="px-3 py-2">' + v.expectedTime + '</td>' +
                    '<td class="px-3 py-2">' + statusBadge + '</td>' +
                    '<td class="px-3 py-2">' + v.approvedByName + '</td>' +
                    '<td class="px-3 py-2">' + v.checkInTime + '</td>' +
                    '<td class="px-3 py-2">' + v.checkOutTime + '</td>' +
                    '<td class="px-3 py-2">' + (v.hasVehicle ? '<i class="fas fa-car text-primary me-1"></i>' + v.vehicleNumber : '<span class="text-muted">None</span>') + '</td>' +
                    '<td class="px-3 py-2">' + v.requestCreatedAt + '</td>' +
                    '</tr>';
            });
            $('#auditTableBody').html(html);
        }

        function updateSummary(data) {
            var hpCount = data.filter(d => d.isUrgent).length;
            $('#summaryTotal').text(data.length);
            $('#summaryHP').text(hpCount);
            $('#summaryPending').text(data.filter(d => d.status === 'Pending').length);
            $('#summaryApproved').text(data.filter(d => d.status === 'Approved').length);
            $('#summaryRejected').text(data.filter(d => d.status === 'Rejected').length);
            $('#summaryCheckedIn').text(data.filter(d => d.status === 'Checked In').length);
            $('#summaryCheckedOut').text(data.filter(d => d.status === 'Checked Out').length);

            if (hpCount > 0) {
                $('#hpFilterBar').show();
                $('#hpCountText').text(hpCount);
            } else {
                $('#hpFilterBar').hide();
            }
        }

        function resetFilters() {
            $('#auditSearch').val('');
            $('#auditStatus').val('all');
            $('#auditDepartment').val('0');
            $('#auditDateFrom').val('');
            $('#auditDateTo').val('');
            hpFilterActive = false;
            $('#hpToggleBtn').removeClass('btn-danger').addClass('btn-outline-danger').html('<i class="fas fa-filter me-1"></i>Show High Priority Only');
            loadAuditData();
        }

        function toggleHpFilter() {
            hpFilterActive = !hpFilterActive;
            var rows = $('#auditTableBody tr[data-hp]');
            if (hpFilterActive) {
                rows.each(function () {
                    $(this).toggle($(this).data('hp') === true);
                });
                $('#hpToggleBtn').removeClass('btn-outline-danger').addClass('btn-danger').html('<i class="fas fa-filter me-1"></i>Show All Visitors');
            } else {
                rows.show();
                $('#hpToggleBtn').removeClass('btn-danger').addClass('btn-outline-danger').html('<i class="fas fa-filter me-1"></i>Show High Priority Only');
            }
        }

        function getExportRows() {
            var exportData = hpFilterActive ? auditData.filter(function(v) { return v.isUrgent; }) : auditData;
            return exportData.map(function (v) {
                return [v.name + (v.isUrgent ? ' [HP]' : ''), v.cnic, v.phone, v.purpose, v.employeeName, v.departmentName,
                        v.expectedTime, v.status, v.approvedByName, v.checkInTime, v.checkOutTime,
                        v.hasVehicle ? v.vehicleNumber : 'None', v.requestCreatedAt];
            });
        }

        var exportHeaders = ['Visitor Name', 'CNIC', 'Phone', 'Purpose', 'Host', 'Department',
                             'Expected', 'Status', 'Approved By', 'Check-In', 'Check-Out', 'Vehicle', 'Requested'];

        function exportPdf() {
            var { jsPDF } = window.jspdf;
            var doc = new jsPDF('landscape', 'mm', 'a4');

            doc.setFontSize(16);
            doc.text('Visitor Audit Trail', 14, 15);
            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text('Generated: ' + new Date().toLocaleString(), 14, 22);

            var filterText = getFilterSummary();
            if (filterText) {
                doc.text('Filters: ' + filterText, 14, 28);
            }

            doc.autoTable({
                head: [exportHeaders],
                body: getExportRows(),
                startY: filterText ? 33 : 27,
                styles: { fontSize: 7, cellPadding: 2 },
                headStyles: { fillColor: [59, 130, 246], textColor: 255 },
                alternateRowStyles: { fillColor: [248, 249, 250] },
                margin: { left: 14, right: 14 }
            });

            doc.save('Visitor_Audit_' + new Date().toISOString().slice(0, 10) + '.pdf');
        }

        function exportExcel() {
            var rows = getExportRows();
            rows.unshift(exportHeaders);

            var ws = XLSX.utils.aoa_to_sheet(rows);
            var wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Audit Trail');

            // Auto-size columns
            ws['!cols'] = exportHeaders.map(function () { return { wch: 18 }; });

            XLSX.writeFile(wb, 'Visitor_Audit_' + new Date().toISOString().slice(0, 10) + '.xlsx');
        }

        function printAudit() {
            var printWin = window.open('', '_blank');
            var tableHtml = document.getElementById('auditTable').outerHTML;
            printWin.document.write('<!DOCTYPE html><html><head><title>Visitor Audit Trail<' + '/title>');
            printWin.document.write('<style>body{font-family:Arial,sans-serif;margin:20px;}table{width:100%;border-collapse:collapse;font-size:10px;}th,td{border:1px solid #ddd;padding:6px 8px;text-align:left;}th{background:#3b82f6;color:#fff;}.badge{padding:2px 6px;border-radius:4px;font-size:9px;color:#fff;}.bg-warning{background:#f59e0b;color:#000!important;}.bg-success{background:#10b981;}.bg-danger{background:#ef4444;}.bg-secondary{background:#6b7280;}h2{margin-bottom:4px;}p{color:#666;margin-top:0;}<' + '/style>');
            printWin.document.write('<' + '/head><body>');
            printWin.document.write('<h2>Visitor Audit Trail<' + '/h2>');
            printWin.document.write('<p>Generated: ' + new Date().toLocaleString() + ' | Records: ' + auditData.length + '<' + '/p>');
            printWin.document.write(tableHtml);
            printWin.document.write('<' + '/body><' + '/html>');
            printWin.document.close();
            printWin.onload = function () { printWin.print(); };
        }

        function getFilterSummary() {
            var parts = [];
            var s = $('#auditSearch').val();
            if (s) parts.push('Search: ' + s);
            var st = $('#auditStatus').val();
            if (st && st !== 'all') parts.push('Status: ' + st);
            var d = $('#auditDepartment option:selected').text();
            if ($('#auditDepartment').val() !== '0') parts.push('Dept: ' + d);
            var df = $('#auditDateFrom').val();
            if (df) parts.push('From: ' + df);
            var dt = $('#auditDateTo').val();
            if (dt) parts.push('To: ' + dt);
            return parts.join(' | ');
        }

        $(document).ready(function () {
            loadAuditData();

            $('#auditSearch').on('input', function () {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(loadAuditData, 400);
            });

            $('#auditStatus, #auditDepartment, #auditDateFrom, #auditDateTo').on('change', loadAuditData);
        });
    </script>

    <style>
        #auditTableContainer {
            max-height: 65vh;
            overflow-y: auto;
        }

        #auditTable thead th {
            white-space: nowrap;
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6b7280;
            border-bottom: 2px solid #e5e7eb;
        }

        #auditTable tbody tr:hover {
            background-color: #f0f9ff !important;
        }

        @@media print {
            .navbar, .breadcrumb, .card-footer, .btn, .form-control, .form-select {
                display: none !important;
            }
            #auditTableContainer {
                max-height: none !important;
                overflow: visible !important;
            }
        }
    </style>
}
