@model VisitorManagementSystemMoD.Models.BlockedVisitor
@{
    ViewData["Title"] = "Block Visitor";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")"><i class="fas fa-home"></i> Dashboard</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "BlockedVisitor")"><i class="fas fa-ban"></i> Blocked Visitors</a></li>
            <li class="breadcrumb-item active" aria-current="page">Block Visitor</li>
        </ol>
    </nav>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="fas fa-ban me-2 text-danger"></i>Block Visitor</h2>
        <p class="text-muted mb-0 small">Add a visitor to the blocked list</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 offset-lg-3">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.7rem;letter-spacing:0.5px;">
                        <i class="fas fa-user-slash me-1"></i>Visitor Details
                    </h6>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-semibold">Visitor Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-sm" placeholder="Enter visitor's full name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CNIC" class="form-label small fw-semibold">CNIC <span class="text-danger">*</span></label>
                        <input asp-for="CNIC" class="form-control form-control-sm" placeholder="e.g., 12345-1234567-1" />
                        <span asp-validation-for="CNIC" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Reason" class="form-label small fw-semibold">Reason for Blocking</label>
                        <textarea asp-for="Reason" class="form-control form-control-sm" rows="3" placeholder="Why is this visitor being blocked?"></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a href="@Url.Action("Index", "BlockedVisitor")" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-sm btn-danger">
                            <i class="fas fa-ban me-1"></i>Block Visitor
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
