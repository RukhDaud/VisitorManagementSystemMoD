
@model IEnumerable<VisitorManagementSystemMoD.Models.Visitor>
@{
    ViewData["Title"] = "All Visitors";
    var status = ViewBag.Status as string ?? "All";
    var entries = ViewBag.Entries ?? 10;
    var totalCount = ViewBag.TotalCount ?? 0;
    var allCount = Model.Count();
    var pendingCount = Model.Count(v => v.Status == "Pending");
    var approvedCount = Model.Count(v => v.Status == "Approved");
    var rejectedCount = Model.Count(v => v.Status == "Rejected");
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")"><i class="fas fa-home"></i> Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">All Visitors</li>
        </ol>
    </nav>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="fas fa-users me-2 text-primary"></i>All Visitors</h2>
        <p class="text-muted mb-0 small">View all visitor requests across the system</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <label class="mb-0 text-muted small">Show</label>
        <select onchange="updateEntries(this.value)" class="form-select form-select-sm" style="width: auto;">
            <option value="10" selected="@(entries == 10)">10</option>
            <option value="25" selected="@(entries == 25)">25</option>
            <option value="50" selected="@(entries == 50)">50</option>
            <option value="100" selected="@(entries == 100)">100</option>
            <option value="-1" selected="@(entries == -1)">All</option>
        </select>
        <span class="text-muted small">entries (Total: @totalCount)</span>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%);">
            <div class="card-body p-3 text-center">
                <p class="text-primary fw-semibold mb-1 small">Total</p>
                <h3 class="fw-bold mb-0 text-primary">@allCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%);">
            <div class="card-body p-3 text-center">
                <p class="fw-semibold mb-1 small" style="color:#92400e;">Pending</p>
                <h3 class="fw-bold mb-0" style="color:#92400e;">@pendingCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #d1fae5 0%, #6ee7b7 100%);">
            <div class="card-body p-3 text-center">
                <p class="fw-semibold mb-1 small" style="color:#059669;">Approved</p>
                <h3 class="fw-bold mb-0" style="color:#059669;">@approvedCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #fee2e2 0%, #fca5a5 100%);">
            <div class="card-body p-3 text-center">
                <p class="fw-semibold mb-1 small" style="color:#dc2626;">Rejected</p>
                <h3 class="fw-bold mb-0" style="color:#dc2626;">@rejectedCount</h3>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4 border-0">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold mb-1">Search</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="visitorSearch" class="form-control" placeholder="Name, CNIC, phone, host...">
                </div>
            </div>
            <div class="col-md-5">
                <label class="form-label small fw-semibold mb-1">Status</label>
                <div class="btn-group btn-group-sm w-100" role="group">
                    <a class="btn @(status == "All" ? "btn-primary" : "btn-outline-secondary")" asp-action="AllVisitors" asp-route-status="All" asp-route-entries="@entries">All (@allCount)</a>
                    <a class="btn @(status == "Pending" ? "btn-warning" : "btn-outline-secondary")" asp-action="AllVisitors" asp-route-status="Pending" asp-route-entries="@entries">Pending (@pendingCount)</a>
                    <a class="btn @(status == "Approved" ? "btn-success" : "btn-outline-secondary")" asp-action="AllVisitors" asp-route-status="Approved" asp-route-entries="@entries">Approved (@approvedCount)</a>
                    <a class="btn @(status == "Rejected" ? "btn-danger" : "btn-outline-secondary")" asp-action="AllVisitors" asp-route-status="Rejected" asp-route-entries="@entries">Rejected (@rejectedCount)</a>
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary btn-sm w-100" onclick="document.getElementById('visitorSearch').value='';filterVisitors();" title="Reset Search">
                    <i class="fas fa-undo me-1"></i>Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Visitors Table -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive" style="max-height: 65vh; overflow-y: auto;">
            <table class="table table-hover mb-0" id="visitorsTable">
                <thead style="position: sticky; top: 0; z-index: 1; background: #f8f9fc;">
                    <tr class="small">
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Visitor</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">CNIC</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Phone</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Host</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Expected Time</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Status</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Vehicle</th>
                        <th class="px-3 py-2 text-muted text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.5px; border-bottom: 2px solid #e5e7eb;">Action</th>
                    </tr>
                </thead>
                <tbody class="small" id="visitorsTableBody">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-users fa-2x mb-2 d-block" style="color:#d1d5db;"></i>
                                No visitors found
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var visitor in Model)
                        {
                            <tr class="visitor-row"
                                data-name="@visitor.Name.ToLower()"
                                data-cnic="@visitor.CNIC.ToLower()"
                                data-phone="@visitor.Phone.ToLower()"
                                data-host="@visitor.EmployeeName.ToLower()">
                                <td class="px-3 py-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold"
                                             style="width:32px;height:32px;font-size:0.75rem;background:linear-gradient(135deg,#60a5fa,#a78bfa);">
                                            @visitor.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-semibold">@visitor.Name</span>
                                    </div>
                                </td>
                                <td class="px-3 py-2 text-muted">@visitor.CNIC</td>
                                <td class="px-3 py-2 text-muted">@visitor.Phone</td>
                                <td class="px-3 py-2">@visitor.EmployeeName</td>
                                <td class="px-3 py-2 text-muted" style="font-size:0.75rem;">@visitor.ExpectedTime.ToString("MMM dd, h:mm tt")</td>
                                <td class="px-3 py-2">
                                    @if (visitor.Status == "Approved")
                                    {
                                        <span class="badge rounded-pill" style="background:#dcfce7;color:#166534;font-weight:500;">Approved</span>
                                    }
                                    else if (visitor.Status == "Pending")
                                    {
                                        <span class="badge rounded-pill" style="background:#fef3c7;color:#92400e;font-weight:500;">Pending</span>
                                    }
                                    else if (visitor.Status == "Rejected")
                                    {
                                        <span class="badge rounded-pill" style="background:#fee2e2;color:#dc2626;font-weight:500;">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;font-weight:500;">@visitor.Status</span>
                                    }
                                </td>
                                <td class="px-3 py-2">
                                    @if (visitor.HasVehicle)
                                    {
                                        <span class="badge rounded-pill" style="background:#eff6ff;color:#1d4ed8;font-weight:500;"><i class="fas fa-car me-1"></i>@visitor.VehicleNumber</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="px-3 py-2">
                                    <button onclick="viewVisitorDetails(@visitor.Id)" class="btn btn-sm btn-outline-primary" style="padding:2px 8px;font-size:0.7rem;" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top d-flex justify-content-between align-items-center py-2">
        <span class="text-muted small" id="visitorRecordCount">@allCount visitor(s)</span>
        <span class="text-muted small">Showing @(status == "All" ? "all" : status.ToLower()) entries</span>
    </div>
</div>

<!-- Visitor Detail Modal -->
<div class="modal fade" id="visitorDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="fas fa-user-circle me-2 text-primary"></i>Visitor Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateEntries(entries) {
            const params = new URLSearchParams(window.location.search);
            params.set('entries', entries);
            window.location.search = params.toString();
        }

        function filterVisitors() {
            var search = document.getElementById('visitorSearch').value.toLowerCase();
            var rows = document.querySelectorAll('.visitor-row');
            var visible = 0;
            rows.forEach(function (row) {
                var name = row.getAttribute('data-name');
                var cnic = row.getAttribute('data-cnic');
                var phone = row.getAttribute('data-phone');
                var host = row.getAttribute('data-host');
                var match = name.includes(search) || cnic.includes(search) || phone.includes(search) || host.includes(search);
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            document.getElementById('visitorRecordCount').textContent = visible + ' visitor(s)';
        }

        document.getElementById('visitorSearch').addEventListener('input', filterVisitors);
    </script>
    <script src="~/js/visitor-details.js"></script>
}
