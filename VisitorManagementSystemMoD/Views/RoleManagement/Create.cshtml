@model VisitorManagementSystemMoD.Models.ViewModels.RoleViewModel
@{
    ViewData["Title"] = "Create Role";
}

@section Breadcrumb {
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")"><i class="fas fa-home"></i> Dashboard</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Administration", "Dashboard")"><i class="fas fa-cogs"></i> Administration</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "RoleManagement")">Role Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Role</li>
        </ol>
    </nav>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="fas fa-plus-circle me-2" style="color:#7c3aed;"></i>Create New Role</h2>
        <p class="text-muted mb-0 small">Define a new role for system access</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 offset-lg-3">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">

                    <h6 class="fw-semibold text-muted text-uppercase mb-3" style="font-size:0.7rem;letter-spacing:0.5px;">
                        <i class="fas fa-shield-alt me-1"></i>Role Details
                    </h6>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label small fw-semibold">Role Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-sm" placeholder="e.g., Manager, Employee, Security Officer" autofocus />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                        <small class="form-text text-muted">Enter a unique name for this role (max 50 characters)</small>
                    </div>

                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <!-- Actions -->
                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a href="@Url.Action("Index", "RoleManagement")" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-sm text-white" style="background:#7c3aed;">
                            <i class="fas fa-save me-1"></i>Create Role
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="alert mt-3 small border-0 shadow-sm" style="background:#eff6ff;color:#1e40af;">
            <i class="fas fa-info-circle me-1"></i> <strong>Tips:</strong>
            Role names must be unique. Once created, roles appear in the user creation dropdown. Only SuperAdmin can manage roles.
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
