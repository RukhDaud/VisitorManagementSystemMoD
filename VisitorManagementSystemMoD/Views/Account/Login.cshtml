@model VisitorManagementSystemMoD.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Visitor Management System</title>
    <script src="~/lib/tailwindcss/tailwind.min.js"></script>
    <script src="~/lib/iconify/iconify-icon.min.js"></script>
    <link href="~/lib/inter-font/inter.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Hide browser's native password toggle */
        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear {
            display: none;
        }

        /* Custom Animations */
        @@keyframes blob {
            0% {
                transform: translate(0px, 0px) scale(1);
            }

            33% {
                transform: translate(30px, -50px) scale(1.1);
            }

            66% {
                transform: translate(-20px, 20px) scale(0.9);
            }

            100% {
                transform: translate(0px, 0px) scale(1);
            }
        }

        .animate-blob {
            animation: blob 12s infinite alternate ease-in-out;
        }

        .animation-delay-2000 {
            animation-delay: 2s;
        }

        .animation-delay-4000 {
            animation-delay: 4s;
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-4 relative overflow-hidden selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Ambient Animated Background -->
    <div class="absolute top-1/4 -left-10 w-96 h-96 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob pointer-events-none"></div>
    <div class="absolute top-1/4 -right-10 w-96 h-96 bg-indigo-300 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob animation-delay-2000 pointer-events-none"></div>
    <div class="absolute -bottom-20 left-1/3 w-96 h-96 bg-fuchsia-300 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob animation-delay-4000 pointer-events-none"></div>

    <!-- Main Login Card -->
    <div class="relative z-10 w-full max-w-md bg-white rounded-3xl shadow-[0_8px_40px_-12px_rgba(0,0,0,0.1)] overflow-hidden border border-slate-100 p-8 sm:p-10 flex flex-col">

        <!-- Logo -->
        <div class="flex items-center gap-3 mb-10">
            <div class="w-10 h-10 rounded-xl bg-slate-900 flex items-center justify-center shadow-sm text-white">
                <iconify-icon icon="solar:users-group-rounded-linear" class="text-xl"></iconify-icon>
            </div>
            <span class="font-semibold tracking-tighter text-xl text-slate-900">Visitor Management System</span>
        </div>

        <!-- Heading -->
        <div class="mb-8">
            <h2 class="text-2xl tracking-tight font-semibold text-slate-900 mb-2">Welcome</h2>
            <p class="text-sm text-slate-500">Enter your credentials to access your dashboard.</p>
        </div>

        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex flex-row gap-3 items-start">
                <iconify-icon icon="solar:danger-circle-linear" class="text-lg text-red-500 flex-shrink-0 mt-0.5"></iconify-icon>
                <div class="text-sm text-red-600">
                    <p class="font-medium mb-1">Authentication failed</p>
                    @Html.ValidationSummary(false, "", new { @class = "text-xs text-red-500" })
                </div>
            </div>
        }

        <!-- Form -->
        <form asp-action="Login" method="post" class="space-y-4">

            <!-- Username Input -->
            <div>
                <label asp-for="Username" class="block text-sm font-medium text-slate-700 mb-1.5">Username</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                        <iconify-icon icon="solar:user-linear" class="text-slate-400 text-lg group-focus-within:text-indigo-500 transition-colors"></iconify-icon>
                    </div>
                    <input asp-for="Username" type="text" placeholder="Enter your username" class="block w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all duration-200 shadow-sm">
                </div>
                <span asp-validation-for="Username" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Password Input -->
            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <label asp-for="Password" class="block text-sm font-medium text-slate-700">Password</label>
                </div>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                        <iconify-icon icon="solar:lock-password-linear" class="text-slate-400 text-lg group-focus-within:text-indigo-500 transition-colors"></iconify-icon>
                    </div>
                    <input asp-for="Password" type="password" id="passwordField" placeholder="••••••••" class="block w-full pl-10 pr-10 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all duration-200 shadow-sm">
                    <button type="button" id="togglePassword" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-400 hover:text-slate-600 transition-colors focus:outline-none" aria-label="Toggle password visibility">
                        <iconify-icon icon="solar:eye-linear" id="eyeIcon" class="text-lg"></iconify-icon>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="w-full py-2.5 px-4 bg-slate-900 hover:bg-slate-800 text-white rounded-xl text-sm font-medium transition-all duration-200 shadow-sm flex items-center justify-center gap-2 group focus:outline-none focus:ring-4 focus:ring-slate-900/10 mt-6">
                Sign In
                <iconify-icon icon="solar:login-2-linear" class="text-lg opacity-70 group-hover:translate-x-0.5 transition-transform"></iconify-icon>
            </button>
        </form>

        <!-- Footer -->
        <div class="mt-10 pt-6 border-t border-slate-100 flex items-center justify-between text-xs text-slate-500">
            <span>©2026 Visitor Management System MoD</span>
            <a href="#" class="hover:text-slate-900 transition-colors">Help &amp; Support</a>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggleBtn = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('passwordField');
            const eyeIcon = document.getElementById('eyeIcon');

            if (toggleBtn && passwordInput && eyeIcon) {
                toggleBtn.addEventListener('click', function() {
                    const isPassword = passwordInput.getAttribute('type') === 'password';

                    // Toggle input type
                    passwordInput.setAttribute('type', isPassword ? 'text' : 'password');

                    // Toggle icon
                    eyeIcon.setAttribute('icon', isPassword ? 'solar:eye-closed-linear' : 'solar:eye-linear');
                });
            }
        });
    </script>

</body>
</html>
