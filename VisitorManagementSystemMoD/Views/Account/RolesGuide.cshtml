@using VisitorManagementSystemMoD.Constants
@inject VisitorManagementSystemMoD.Services.IAuthorizationService AuthService

@{
    ViewData["Title"] = "Roles & Permissions Guide";
    var userRole = Context.Session.GetString("UserRole");
    var allRoles = RolePermissionsMapping.GetAllRoles().ToList();
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-2">
                <i class="fas fa-user-shield text-primary me-2"></i>Roles & Permissions Guide
            </h1>
            <p class="text-muted">Comprehensive overview of system roles and their permissions</p>
        </div>
        <div>
            <span class="badge bg-primary fs-6">Your Role: @userRole</span>
        </div>
    </div>

    <!-- Role Cards -->
    <div class="row g-4 mb-4">
        @foreach (var role in allRoles)
        {
            var permissions = RolePermissionsMapping.GetPermissionsForRole(role);
            var description = RoleDescriptions.GetDescription(role);
            var isCurrentRole = role == userRole;

            <div class="col-lg-6">
                <div class="card h-100 @(isCurrentRole ? "border-primary shadow" : "")">
                    <div class="card-header @(isCurrentRole ? "bg-primary text-white" : "bg-light")">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fas fa-user-tag me-2"></i>@role
                            </h5>
                            @if (isCurrentRole)
                            {
                                <span class="badge bg-white text-primary">Your Role</span>
                            }
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">@description</p>
                        
                        <div class="mb-3">
                            <h6 class="fw-semibold mb-2">
                                <i class="fas fa-key text-warning me-2"></i>Permissions (@permissions.Count)
                            </h6>
                            <div class="accordion" id="accordion-@role.Replace(" ", "")">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@role.Replace(" ", "")">
                                            View All Permissions
                                        </button>
                                    </h2>
                                    <div id="collapse-@role.Replace(" ", "")" class="accordion-collapse collapse" data-bs-parent="#accordion-@role.Replace(" ", "")">
                                        <div class="accordion-body">
                                            <div class="row g-2">
                                                @foreach (var permission in permissions.OrderBy(p => p))
                                                {
                                                    <div class="col-md-6">
                                                        <span class="badge bg-success bg-opacity-10 text-success w-100 text-start py-2">
                                                            <i class="fas fa-check-circle me-1"></i>@permission
                                                        </span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Permission Matrix -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">
                <i class="fas fa-table me-2"></i>Permission Matrix
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 30%">Feature / Permission</th>
                            @foreach (var role in allRoles)
                            {
                                <th class="text-center">@role</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var allPermissions = new[] {
                                ("View All Requests", Permissions.ViewAllVisitorRequests),
                                ("Create Visitor", Permissions.CreateVisitorRequest),
                                ("Edit Personal Visitor", Permissions.EditPersonalVisitorRequest),
                                ("Edit Any Visitor", Permissions.EditAnyVisitorRequest),
                                ("Delete Personal Visitor", Permissions.DeletePersonalVisitorRequest),
                                ("Delete Any Visitor", Permissions.DeleteAnyVisitorRequest),
                                ("Approve Requests", Permissions.ApproveVisitorRequest),
                                ("Reject Requests", Permissions.RejectVisitorRequest),
                                ("Check-In Visitor", Permissions.CheckInVisitor),
                                ("Check-Out Visitor", Permissions.CheckOutVisitor),
                                ("Generate All Reports", Permissions.GenerateAllReports),
                                ("Generate Visitor Reports", Permissions.GenerateVisitorReports),
                                ("Generate Limited Reports", Permissions.GenerateLimitedReports),
                                ("Create User", Permissions.CreateUser),
                                ("Edit User", Permissions.EditUser),
                                ("Delete User", Permissions.DeleteUser),
                                ("Create Role", Permissions.CreateRole),
                                ("Edit Role", Permissions.EditRole),
                                ("Assign Roles", Permissions.AssignRoles),
                                ("Create Department", Permissions.CreateDepartment),
                                ("Edit Department", Permissions.EditDepartment),
                                ("Access Admin Panel", Permissions.AccessAdminPanel),
                                ("Manage System Settings", Permissions.ManageSystemSettings)
                            };
                        }

                        @foreach (var (displayName, permission) in allPermissions)
                        {
                            <tr>
                                <td>
                                    <strong>@displayName</strong>
                                    <br />
                                    <small class="text-muted">@permission</small>
                                </td>
                                @foreach (var role in allRoles)
                                {
                                    var hasPermission = RolePermissionsMapping.HasPermission(role, permission);
                                    <td class="text-center @(hasPermission ? "table-success" : "table-light")">
                                        @if (hasPermission)
                                        {
                                            <i class="fas fa-check-circle text-success fs-5"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-times-circle text-muted"></i>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Legend -->
    <div class="card mt-4 shadow-sm">
        <div class="card-header bg-info text-white">
            <h6 class="mb-0">
                <i class="fas fa-info-circle me-2"></i>Legend
            </h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        <strong>Green Check:</strong> Role has this permission
                    </p>
                    <p class="mb-2">
                        <i class="fas fa-times-circle text-muted me-2"></i>
                        <strong>Gray X:</strong> Role does NOT have this permission
                    </p>
                </div>
                <div class="col-md-6">
                    <p class="mb-0 text-muted">
                        <i class="fas fa-lightbulb text-warning me-2"></i>
                        <strong>Note:</strong> Only SuperAdmin can modify role permissions. If you need additional permissions, please contact your system administrator.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-4">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</div>

@section Scripts {
    <style>
        .table-success {
            background-color: rgba(25, 135, 84, 0.1) !important;
        }
        
        .accordion-button:not(.collapsed) {
            background-color: #0d6efd;
            color: white;
        }
        
        .card-header {
            font-weight: 600;
        }
    </style>
}
